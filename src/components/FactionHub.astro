---
import MainLayout from "../layouts/MainLayout.astro";
type Icon = "briefcase" | "broadcast" | "users" | "mask" | "network" | "vault";

interface Card {
  id: string;
  badge: string;
  eyebrow: string;
  title: string;
  description: string;
  icon: Icon;
  departments: string[];
  ctaLabel?: string;
}

interface Props {
  pageTitle: string;
  badge: string;
  titleLines: string[];
  lead: string;
  indexLabel: string;
  footerLabel: string;
  dividerLabel: string;
  dividerMeta: string;
  stats: Array<{ value: string; label: string }>;
  cards: Card[];
  heroBackground: string;
  cardBackground: string;
  cardGlow: string;
  accentColor: string;
  accentSoft: string;
  accentBorder: string;
  iconColor: string;
  ctaTitle: string;
  ctaBody: string;
  ctaHref?: string;
  showCards?: boolean;
  wipBox?: {
    label: string;
    title: string;
    body: string;
  };
}

const {
  pageTitle,
  badge,
  titleLines,
  lead,
  indexLabel,
  footerLabel,
  dividerLabel,
  dividerMeta,
  stats,
  cards,
  heroBackground,
  cardBackground,
  cardGlow,
  accentColor,
  accentSoft,
  accentBorder,
  iconColor,
  ctaTitle,
  ctaBody,
  ctaHref = "/#apply",
  showCards = true,
  wipBox,
} = Astro.props as Props;

const titleAccent = titleLines[titleLines.length - 1] ?? "";
const titlePrefix = titleLines.slice(0, Math.max(0, titleLines.length - 1));
const themeStyle = [
  `--hub-accent:${accentColor}`,
  `--hub-accent-soft:${accentSoft}`,
  `--hub-accent-border:${accentBorder}`,
  `--hub-icon-color:${iconColor}`,
  `--hub-hero-bg:${heroBackground}`,
  `--hub-card-bg:${cardBackground}`,
  `--hub-card-glow:${cardGlow}`,
].join(";");
---

<MainLayout title={pageTitle}>
  <div class="hub-page" style={themeStyle}>
    <section class="hub-hero">
      <div class="hub-hero-bg" aria-hidden="true"></div>
      <div class="hub-hero-grid" aria-hidden="true"></div>
      <div class="hub-hero-vignette" aria-hidden="true"></div>

      <div class="container hub-hero-shell">
        <a href="/factions" class="back-link reveal" style="--delay: 0ms">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12.25 8H3.75M3.75 8L7.25 4.5M3.75 8L7.25 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All Factions
        </a>

      <div class="hub-hero-row">
        <div class="hub-hero-copy">
          <div class="hub-badge reveal" style="--delay: 60ms">{badge}</div>

          <h1 class="hub-title reveal" style="--delay: 120ms">
            {titlePrefix.map((line) => <span class="hub-title-line">{line}</span>)}
            <span class="hub-title-line hub-title-line--accent">{titleAccent}</span>
          </h1>

          <p class="hub-lead reveal" style="--delay: 200ms">{lead}</p>

          <div class="hub-stats reveal" style="--delay: 280ms">
            {stats.map((stat) => (
              <div class="hub-stat">
                <span class="hub-stat-num">{stat.value}</span>
                <span class="hub-stat-label">{stat.label}</span>
              </div>
            ))}
          </div>
        </div>

        <aside class="hub-index reveal" style="--delay: 340ms" aria-label="Division index">
          <div class="hub-index-header">
            <span class="hub-index-eyebrow">{indexLabel}</span>
            <span class="hub-index-rule"></span>
          </div>

          <ul class="hub-index-list">
            {cards.map((card, i) => (
              <li>
                <a href={`#division-${card.id}`} class="hub-index-row">
                  <span class="hub-index-num">{String(i + 1).padStart(2, "0")}</span>
                  <span class="hub-index-meta">
                    <span class="hub-index-name">{card.title}</span>
                    <span class="hub-index-tag">{card.badge}</span>
                  </span>
                  <span class="hub-index-arrow" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M3 7H11M11 7L7.5 3.5M11 7L7.5 10.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </a>
              </li>
            ))}
          </ul>

          <div class="hub-index-footer">
            <span class="hub-index-pulse" aria-hidden="true"></span>
            {footerLabel}
          </div>
        </aside>
      </div>
      </div>
    </section>

  <div class="hub-divider container">
    <span class="hub-divider-eyebrow">{dividerLabel}</span>
    <span class="hub-divider-line"></span>
    <span class="hub-divider-meta">{dividerMeta}</span>
  </div>

  <section class="hub-rows-section">
    <div class="container">
      {showCards ? (
        <div class="hub-rows">
          {cards.map((card, i) => (
            <article id={`division-${card.id}`} class="col-card reveal-card" style={`--delay: ${i * 90}ms`}>
              <div class="col-card-media">
                <div class="col-card-media-glow" aria-hidden="true"></div>
                <div class="col-card-media-grid" aria-hidden="true"></div>
                <div class="col-card-media-iconwrap" aria-hidden="true">
                  <svg class="col-card-media-icon" width="120" height="120" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                    {card.icon === "briefcase" && (
                      <g>
                        <rect x="12" y="20" width="40" height="26" rx="4" stroke="currentColor" stroke-width="2"/>
                        <path d="M24 20V16C24 13.8 25.8 12 28 12H36C38.2 12 40 13.8 40 16V20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M12 30H52" stroke="currentColor" stroke-width="2"/>
                        <path d="M28 30V34H36V30" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                      </g>
                    )}
                    {card.icon === "broadcast" && (
                      <g>
                        <path d="M14 42C18 38 24 36 32 36C40 36 46 38 50 42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M20 34C23 30.5 27.5 28 32 28C36.5 28 41 30.5 44 34" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M26 26C27.8 24 29.9 23 32 23C34.1 23 36.2 24 38 26" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="32" cy="20" r="3" stroke="currentColor" stroke-width="2"/>
                      </g>
                    )}
                    {card.icon === "users" && (
                      <g>
                        <circle cx="24" cy="24" r="6" stroke="currentColor" stroke-width="2"/>
                        <circle cx="40" cy="26" r="5" stroke="currentColor" stroke-width="2" opacity="0.75"/>
                        <path d="M14 44C14 38.5 18.5 34 24 34C29.5 34 34 38.5 34 44" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M34 44C34 39.5 37.5 36 42 36C46.5 36 50 39.5 50 44" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.75"/>
                      </g>
                    )}
                    {card.icon === "mask" && (
                      <g>
                        <path d="M18 20L32 14L46 20V28C46 38 39 46 32 50C25 46 18 38 18 28V20Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                        <path d="M24 30C25.5 28 27.5 27 30 27C32.5 27 34.5 28 36 30" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M28 36C29.5 37 30.8 37.5 32 37.5C33.2 37.5 34.5 37 36 36" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="27" cy="24" r="2" fill="currentColor"/>
                        <circle cx="37" cy="24" r="2" fill="currentColor"/>
                      </g>
                    )}
                    {card.icon === "network" && (
                      <g>
                        <circle cx="20" cy="20" r="5" stroke="currentColor" stroke-width="2"/>
                        <circle cx="44" cy="20" r="5" stroke="currentColor" stroke-width="2"/>
                        <circle cx="32" cy="42" r="5" stroke="currentColor" stroke-width="2"/>
                        <path d="M24 23L29 37" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M40 23L35 37" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M25 20H39" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      </g>
                    )}
                    {card.icon === "vault" && (
                      <g>
                        <rect x="16" y="14" width="32" height="36" rx="4" stroke="currentColor" stroke-width="2"/>
                        <circle cx="32" cy="32" r="8" stroke="currentColor" stroke-width="2"/>
                        <path d="M32 24V40" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M24 32H40" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <circle cx="32" cy="32" r="2.5" fill="currentColor"/>
                      </g>
                    )}
                  </svg>
                </div>
                <div class="col-card-tag">{card.badge}</div>
                <div class="col-card-eyebrow">{card.eyebrow}</div>
              </div>

              <div class="col-card-body">
                <div class="col-card-body-main">
                  <h3 class="col-card-title">{card.title}</h3>
                  <p class="col-card-desc">{card.description}</p>
                  <ul class="col-card-departments">
                    {card.departments.map((dep) => <li>{dep}</li>)}
                  </ul>
                </div>

                <div class="col-card-cta">
                  <span>{card.ctaLabel ?? "Work in Progress"}</span>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : wipBox ? (
        <article class="hub-wip-box reveal-card">
          <div class="hub-wip-box-inner">
            <span class="hub-wip-box-label">{wipBox.label}</span>
            <h2 class="hub-wip-box-title">{wipBox.title}</h2>
            <p class="hub-wip-box-body">{wipBox.body}</p>
          </div>
        </article>
      ) : null}
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <div>
          <h3>{ctaTitle}</h3>
          <p>{ctaBody}</p>
        </div>
        <a class="button" href={ctaHref}>Apply for Whitelist</a>
      </div>
    </div>
  </section>
  </div>
</MainLayout>

<style>
  @keyframes reveal-up {
    0% { opacity: 0; transform: translate3d(0, 14px, 0); }
    100% { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @keyframes card-reveal {
    0% { opacity: 0; transform: translate3d(0, 22px, 0); }
    100% { opacity: 1; transform: translate3d(0, 0, 0); }
  }

  @keyframes aurora-drift {
    0% { transform: translate3d(0, 0, 0) scale(1); }
    50% { transform: translate3d(-2%, 1%, 0) scale(1.04); }
    100% { transform: translate3d(0, 0, 0) scale(1); }
  }

  .reveal {
    opacity: 0;
    animation: reveal-up 720ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  .reveal-card {
    opacity: 0;
    animation: card-reveal 760ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  .hub-hero {
    --nav-bleed: 130px;
    position: relative;
    overflow: hidden;
    margin-top: calc(var(--nav-bleed) * -1);
    padding-top: calc(110px + var(--nav-bleed));
    padding-bottom: 90px;
  }

  .hub-hero-bg,
  .hub-hero-grid,
  .hub-hero-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hub-hero-bg {
    z-index: 0;
    background: var(--hub-hero-bg);
    animation: aurora-drift 22s ease-in-out infinite;
  }

  .hub-hero-grid {
    z-index: 1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 60%, black 0%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 60%, black 0%, transparent 80%);
    opacity: 0.55;
  }

  .hub-hero-vignette {
    z-index: 2;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(4, 10, 18, 0) 66%,
      rgba(4, 10, 18, 0.88) 90%,
      #040a11 100%
    );
  }

  .hub-hero-shell {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #9db0c6;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    align-self: flex-start;
  }

  .back-link:hover { color: #f4f8ff; }

  .hub-hero-row {
    display: grid;
    grid-template-columns: 1.45fr 1fr;
    gap: 64px;
    align-items: end;
  }

  .hub-hero-copy {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .hub-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    min-height: 32px;
    padding: 0 14px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--hub-accent) 12%, transparent);
    border: 1px solid var(--hub-accent-border);
    color: var(--hub-accent-soft);
  }

  .hub-badge::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--hub-accent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--hub-accent) 60%, transparent);
  }

  .hub-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.6rem, 6vw, 5rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
    color: #f4f8ff;
    margin: 0;
  }

  .hub-title-line { display: block; }

  .hub-title-line--accent {
    background: linear-gradient(120deg, var(--hub-accent-soft) 0%, #f4f8ff 70%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hub-lead {
    color: #9db0c6;
    font-size: 1.05rem;
    line-height: 1.78;
    max-width: 56ch;
  }

  .hub-stats {
    display: flex;
    align-items: stretch;
    margin-top: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 18px 0;
  }

  .hub-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 36px;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hub-stat:first-child { padding-left: 0; }
  .hub-stat:last-child { border-right: none; }

  .hub-stat-num {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.65rem;
    font-weight: 700;
    color: #f4f8ff;
  }

  .hub-stat-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #7d92aa;
    font-weight: 600;
  }

  .hub-index {
    position: relative;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255,255,255,0.045) 0%, rgba(255,255,255,0.02) 100%);
    padding: 22px;
    backdrop-filter: blur(10px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.32);
  }

  .hub-index-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .hub-index-eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #7d92aa;
  }

  .hub-index-rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.12), transparent);
  }

  .hub-index-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hub-index-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 14px;
    border-radius: 14px;
    border: 1px solid transparent;
    background: rgba(255, 255, 255, 0.02);
    text-decoration: none;
    color: inherit;
  }

  .hub-index-row:hover,
  .hub-index-row:focus-visible {
    background: color-mix(in srgb, var(--hub-accent) 8%, transparent);
    border-color: color-mix(in srgb, var(--hub-accent) 32%, transparent);
    transform: translateX(4px);
    outline: none;
  }

  .hub-index-num {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #5b6f88;
    width: 26px;
    text-align: center;
  }

  .hub-index-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hub-index-name {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.98rem;
    font-weight: 600;
    color: #f4f8ff;
  }

  .hub-index-tag {
    font-size: 0.7rem;
    color: #7d92aa;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hub-index-arrow {
    color: rgba(244, 248, 255, 0.35);
    display: grid;
    place-items: center;
  }

  .hub-index-footer {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.74rem;
    color: #7d92aa;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .hub-index-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--hub-accent);
    box-shadow: 0 0 12px color-mix(in srgb, var(--hub-accent) 65%, transparent);
  }

  .hub-divider {
    display: flex;
    align-items: center;
    gap: 18px;
    padding-top: 8px;
    padding-bottom: 32px;
  }

  .hub-divider-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #9db0c6;
  }

  .hub-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.16), rgba(255,255,255,0.04));
  }

  .hub-divider-meta {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.78rem;
    color: #7d92aa;
    font-weight: 600;
  }

  .hub-rows-section { padding-bottom: 110px; }

  .hub-rows {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .hub-wip-box {
    position: relative;
    overflow: hidden;
    display: grid;
    place-items: center;
    min-height: 320px;
    padding: 40px;
    border-radius: 28px;
    border: 1px solid var(--hub-accent-border);
    background:
      radial-gradient(circle at 18% 20%, rgba(255, 255, 255, 0.08) 0%, transparent 24%),
      radial-gradient(circle at 82% 72%, rgba(255, 255, 255, 0.06) 0%, transparent 26%),
      linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015)),
      var(--hub-card-bg);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 22px 60px rgba(0, 0, 0, 0.34);
  }

  .hub-wip-box::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(circle at 50% 50%, black 26%, transparent 88%);
    -webkit-mask-image: radial-gradient(circle at 50% 50%, black 26%, transparent 88%);
    opacity: 0.5;
    pointer-events: none;
  }

  .hub-wip-box-inner,
  .hub-wip-box-label,
  .hub-wip-box-title,
  .hub-wip-box-body {
    position: relative;
    z-index: 1;
  }

  .hub-wip-box-inner {
    width: min(100%, 680px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hub-wip-box-label {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 14px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--hub-accent) 12%, transparent);
    border: 1px solid var(--hub-accent-border);
    color: var(--hub-accent-soft);
  }

  .hub-wip-box-title {
    margin: 20px 0 10px;
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: #f4f8ff;
  }

  .hub-wip-box-body {
    margin: 0;
    color: #9db0c6;
    font-size: 1rem;
    line-height: 1.8;
  }

  .col-card {
    display: flex;
    flex-direction: column;
    border-radius: 26px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.34);
