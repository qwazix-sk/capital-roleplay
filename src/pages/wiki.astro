<script>
  const links = document.querySelectorAll(".wiki-link");
  const articles = document.querySelectorAll(".wiki-article");
  const nextBtn = document.getElementById("wiki-next-btn") as HTMLAnchorElement | null;
  const nextTitle = document.getElementById("wiki-next-title");

  const articleOrder = [
    { id: "home",          label: "Welcome" },
    { id: "rules",         label: "Rules" },
    { id: "how-to-join",   label: "How to Join the Server" },
    { id: "verify",        label: "How to Verify" },
    { id: "whitelist",     label: "How to Apply for Whitelist" },
    { id: "faq",           label: "FAQ" },
    { id: "starter-guide", label: "Starter Guide" },
    { id: "weapon-guide",  label: "General Weapon Guide" },
    { id: "vehicle-guide", label: "Vehicle Garage System" },
    { id: "house-guide",   label: "House Guide" },
    { id: "controls",      label: "Controls & Keybinds" },
  ];

  function updateNextBtn(currentId: string) {
    const idx = articleOrder.findIndex((a) => a.id === currentId);
    if (!nextBtn || !nextTitle) return;
    if (idx !== -1 && idx < articleOrder.length - 1) {
      const next = articleOrder[idx + 1];
      nextBtn.style.display = "flex";
      nextBtn.dataset.article = next.id;
      nextTitle.textContent = next.label;
    } else {
      nextBtn.style.display = "none";
    }
  }

  function showArticle(id: string) {
    articles.forEach((a) => a.classList.remove("active"));
    links.forEach((l) => l.classList.remove("active"));

    const target = document.getElementById("article-" + id);
    if (target) target.classList.add("active");

    const activeLink = document.querySelector(`.wiki-link[data-article="${id}"]`);
    if (activeLink) activeLink.classList.add("active");

    updateNextBtn(id);
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const id = (link as HTMLElement).dataset.article;
      if (id) showArticle(id);
    });
  });

  document.querySelectorAll(".wiki-card[data-article]").forEach((card) => {
    card.addEventListener("click", (e) => {
      e.preventDefault();
      const id = (card as HTMLElement).dataset.article;
      if (id) showArticle(id);
    });
  });

  if (nextBtn) {
    nextBtn.addEventListener("click", (e) => {
      e.preventDefault();
      const id = nextBtn.dataset.article;
      if (id) showArticle(id);
    });
  }

  // Initialise next button for the default active article
  updateNextBtn("home");
</script>
