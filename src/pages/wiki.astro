---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Wiki — Capital Roleplay">
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Server reference</div>
        <h1>Server knowledge, guides, and core information.</h1>
        <p class="lead">
          This page should later hold onboarding guides, faction information, economy notes,
          server systems, legal structures, criminal progression, and other permanent reference content.
        </p>
      </div>

      <div class="cards">
        <article class="card">
          <h3>Getting Started</h3>
          <p>
            Reserved for joining steps, whitelist guidance, city onboarding,
            and first-session setup.
          </p>
        </article>

        <article class="card">
          <h3>Server Systems</h3>
          <p>
            Reserved for economy, jobs, businesses, progression systems,
            and unique gameplay mechanics.
          </p>
        </article>

        <article class="card">
          <h3>Faction Information</h3>
          <p>
            Reserved for legal and illegal faction expectations,
            requirements, and reference material.
          </p>
        </article>
      </div>
    </div>
  </section>
</MainLayout>