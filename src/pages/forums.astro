---
const storeUrl = "https://your-tebex-store-link.tebex.io";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Forums — Capital Roleplay</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap');

      :root {
        --bg: #061019;
        --panel: rgba(255,255,255,0.045);
        --border: rgba(255,255,255,0.09);
        --text: #f4f8ff;
        --muted: #9db0c6;
        --primary: #00aeff;
        --shadow: 0 10px 40px rgba(0,0,0,0.34);
        --max: 1200px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: "Inter", sans-serif;
        color: var(--text);
        background: linear-gradient(180deg, #07111a 0%, #050b12 100%);
      }
      a { color: inherit; text-decoration: none; }
      .container { width: min(var(--max), calc(100% - 32px)); margin: 0 auto; }
      .nav {
        display: flex; justify-content: space-between; align-items: center;
        padding: 24px 0;
      }
      .brand { display: flex; align-items: center; gap: 12px; }
      .logo {
        width: 42px; height: 42px; border-radius: 999px; overflow: hidden;
        border: 1px solid rgba(255,255,255,0.08);
      }
      .logo img { width: 100%; height: 100%; object-fit: cover; }
      .links { display: flex; gap: 18px; }
      .hero { padding: 72px 0 28px; }
      h1 {
        font-family: "Space Grotesk", sans-serif;
        font-size: clamp(2.6rem, 6vw, 4.8rem);
        letter-spacing: -0.05em;
        line-height: 0.95;
      }
      p.lead {
        color: var(--muted);
        max-width: 800px;
        line-height: 1.8;
        margin-top: 18px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        padding: 34px 0 90px;
      }
      .card {
        border-radius: 24px;
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.03));
        box-shadow: var(--shadow);
        padding: 24px;
      }
      .card h3 {
        font-family: "Space Grotesk", sans-serif;
        margin-bottom: 12px;
      }
      .card p {
        color: var(--muted);
        line-height: 1.75;
      }
      @media (max-width: 900px) {
        .grid { grid-template-columns: 1fr; }
        .links { display: none; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <nav class="nav">
        <a href="/" class="brand">
          <div class="logo"><img src="/logo.png" alt="Capital Roleplay logo" /></div>
          <strong>Capital Roleplay</strong>
        </a>
        <div class="links">
          <a href="/">About Us</a>
          <a href="/factions">Factions</a>
          <a href="/forums">Forums</a>
          <a href={storeUrl} target="_blank" rel="noreferrer">Store</a>
        </div>
      </nav>

      <section class="hero">
        <h1>Forums and community structure.</h1>
        <p class="lead">
          This page should later hold announcements, rule posts, faction updates, appeals, guides, and application-related information.
          For now, it works as a clean internal page to support the navigation structure.
        </p>
      </section>

      <section class="grid">
        <article class="card">
          <h3>Announcements</h3>
          <p>Reserved for important updates, launch notices, server changes, and community news.</p>
        </article>
        <article class="card">
          <h3>Guides & Rules</h3>
          <p>Reserved for onboarding, roleplay standards, server expectations, and helpful player guides.</p>
        </article>
        <article class="card">
          <h3>Applications & Appeals</h3>
          <p>Reserved for whitelist updates, appeals, support threads, and future forum-driven workflows.</p>
        </article>
      </section>
    </div>
  </body>
</html>