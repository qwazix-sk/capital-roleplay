        body: "Major crime (armed robbery, drive-bys, hostage scenes) is prohibited within the immediate vicinity of government and civil service buildings unless part of a staff-approved large-scale scenario.",
      },
      {
        id: "7.4",
        title: "Crime Escalation Zones",
        severity: "note",
        body: "Drug markets, arms routes, and contested turf are high-risk by design. Entering implies acknowledgement of risk, but lethal force still requires proper initiation.",
      },
      {
        id: "7.5",
        title: "Aircraft Restrictions",
        severity: "failrp",
        body: "Aircraft are a privilege restricted to whitelisted roles. Stealing, flying, or using aircraft to evade police, drop into conflicts, or shortcut chases without authorisation is FailRP.",
      },
    ],
  },
  {
    num: "08",
    slug: "section-8",
    variant: "danger",
    icon: "fa-bug",
    title: "Cheating, Exploits & Integrity",
    description:
      "Zero tolerance. Every rule in this section is enforced strictly and most carry permanent bans. Read carefully.",
    tocLabel: "Integrity",
    rules: [
      {
        id: "8.1",
        title: "Cheats & Hacks",
        severity: "permaban",
        body: "Any third-party cheat, modification, or injected client granting unfair advantage, including godmode, speed hacks, teleport, ESP, aimbot, or stat manipulation, is a permanent ban with no appeal.",
      },
      {
        id: "8.2",
        title: "Bug & Mechanic Exploitation",
        severity: "bannable",
        body: "Knowingly using a server or game bug for advantage is bannable. Discovering a bug carries an obligation to report it via ticket; continued use after discovery is treated as exploiting.",
      },
      {
        id: "8.3",
        title: "Macros & External Tools",
        severity: "bannable",
        body: "Macros, auto-clickers, scripts automating inputs, weighted controllers, and any tool simulating presence or actions are not permitted. Only official FiveM graphics enhancements are allowed.",
      },
      {
        id: "8.4",
        title: "AFK Farming",
        severity: "bannable",
        body: "Generating money, XP, or items while not actively at the keyboard, including macro-driven jobs and weighted keys, is prohibited and forfeits all gains.",
      },
      {
        id: "8.5",
        title: "Duplication & Asset Exploits",
        severity: "permaban",
        body: "Money, item, or asset duplication via exploit, server error, or cross-character transfer is a permanent ban plus full asset wipe for every involved account.",
      },
      {
        id: "8.6",
        title: "Reporting Obligation",
        severity: "note",
        body: "Players who discover an exploit must report it immediately via ticket. Good-faith reporters are rewarded; players who exploit first and report later are still sanctioned.",
      },
      {
        id: "8.7",
        title: "Report Evidence",
        severity: "note",
        body: "Reports require unedited video evidence with timestamps and clear context. Edited clips, isolated screenshots, and second-hand accounts are not sufficient for sanction.",
      },
    ],
  },
];

const totalRules = sections.reduce((acc, s) => {
  if (s.rules) return acc + s.rules.length;
  if (s.subsections) return acc + s.subsections.reduce((a, sub) => a + sub.rules.length, 0);
  return acc;
}, 0);

const lastRevised = "May 2026";
---

<MainLayout title="Rules — Capital Roleplay">

  <div class="rules-page">

    <!-- Page header -->
    <div class="rules-header">
      <div class="rules-outer">
        <div class="eyebrow">Server Rulebook</div>
        <h1 class="rules-title">Capital Roleplay<br /><span>Rules</span></h1>
        <p class="rules-subtitle">
          Read and understand the ruleset before entering the city. Ignorance is not a valid
          defence. Staff hold final discretion in all situations not explicitly covered below.
        </p>
      </div>
    </div>

    <!-- Stats row -->
    <div class="rules-outer">
      <div class="rules-stats-row">
        <div class="rules-stat">
          <i class="fa-solid fa-list-ol"></i>
          <span>{totalRules} rules across {sections.length} sections</span>
        </div>
        <div class="rules-stat rules-stat--warn">
          <i class="fa-solid fa-ban"></i>
          <span>Zero tolerance for cheating</span>
        </div>
        <div class="rules-stat">
          <i class="fa-solid fa-gavel"></i>
          <span>Staff hold final discretion</span>
        </div>
        <div class="rules-stat">
          <i class="fa-solid fa-clock-rotate-left"></i>
          <span>Last revised {lastRevised}</span>
        </div>
      </div>
    </div>

    <!-- Two-column layout -->
    <div class="rules-outer">
      <div class="rules-shell">

        <!-- Sticky TOC -->
        <aside class="rules-sidebar">
          <p class="rules-toc-label">On this page</p>
          <nav class="rules-toc">
            {sections.map((s) => (
              <a href={`#${s.slug}`} class="rules-toc-link" data-section={s.slug}>
                <span class="rules-toc-icon"><i class={`fa-solid ${s.icon}`}></i></span>
                <span class="rules-toc-num">{s.num}</span>{s.tocLabel}
              </a>
            ))}
          </nav>
        </aside>

        <!-- Rules content -->
        <main class="rules-main">

          <!-- Global notice -->
          <div class="rules-notice">
            <i class="fa-solid fa-circle-info"></i>
            <div>
              These rules are effective immediately and subject to update without prior notice.
              Violations may result in a warning, kick, temporary ban, or permanent ban at staff
              discretion. <strong>Last revised: {lastRevised}.</strong>
            </div>
          </div>

          {sections.map((section) => (
            <section id={section.slug} class="rules-section">
              <div
                class:list={[
                  "rules-section-header",
                  section.variant && `rules-section-header--${section.variant}`,
                ]}
                data-num={section.num}
              >
                <div class="rules-section-watermark">{section.num}</div>
                <div class="rules-section-inner">
                  <div
                    class:list={[
                      "rules-section-icon-wrap",
                      section.variant && `rules-section-icon-wrap--${section.variant}`,
                    ]}
                  >
                    <i class={`fa-solid ${section.icon}`}></i>
                  </div>
                  <div class="rules-section-copy">
                    <div
                      class:list={[
                        "rules-section-badge",
                        section.variant && `rules-section-badge--${section.variant}`,
                      ]}
                    >
                      Section {section.num}
                    </div>
                    <h2>{section.title}</h2>
                    <p>{section.description}</p>
                  </div>
                </div>
              </div>

              {section.rules && (
                <div class="rules-list">
                  {section.rules.map((rule) => (
                    <div class="rule-item" id={`rule-${rule.id}`}>
                      <a class="rule-num" href={`#rule-${rule.id}`} aria-label={`Link to rule ${rule.id}`}>{rule.id}</a>
                      <div class="rule-body">
                        <div class="rule-head">
                          <strong set:html={rule.title} />
                          <span class={`severity-pill severity-pill--${rule.severity}`}>
                            <i class={`fa-solid ${sevIcon[rule.severity]}`}></i>
                            {sevLabel[rule.severity]}
                          </span>
                        </div>
                        <p set:html={rule.body} />
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {section.subsections && (
                <div class="rules-subsections">
                  {section.subsections.map((sub) => (
                    <div class="rules-subsection" id={`${section.slug}-${sub.id}`}>
                      <div class="rules-subsection-heading">
                        <span class="rules-subsection-rule"></span>
                        <span class="rules-subsection-label">{sub.label}</span>
                      </div>

                      <div class="rules-list">
                        {sub.rules.map((rule) => (
                          <>
                            {rule.display === "tier-cards" && (
                              <div class="tier-cards">
                                <div class="tier-card tier-card--one">
                                  <div class="tier-card-head">
                                    <span class="tier-card-tag">Tier 1</span>
                                    <span class="tier-card-label">Non-Whitelisted</span>
                                  </div>
                                  <h3 class="tier-card-title">Up to 6 members</h3>
                                  <ul class="tier-card-list">
                                    <li>Shared clothing colour only</li>
                                    <li>No flags or masks</li>
                                    <li>No official perks</li>
                                    <li>Build rep before applying for whitelist</li>
                                  </ul>
                                </div>
                                <div class="tier-card tier-card--two">
                                  <div class="tier-card-head">
                                    <span class="tier-card-tag tier-card-tag--two">Tier 2</span>
                                    <span class="tier-card-label">Whitelisted</span>
                                  </div>
                                  <h3 class="tier-card-title">Up to 12 members</h3>
                                  <ul class="tier-card-list">
                                    <li>Identifier required at all times</li>
                                    <li>Flag, mask, or registered colours</li>
                                    <li>Eligible for gang wars &amp; territory</li>
                                    <li>Access to shipments &amp; supplier arcs</li>
                                  </ul>
                                </div>
                              </div>
                            )}

                            <div class="rule-item" id={`rule-${rule.id}`}>
                              <a class="rule-num" href={`#rule-${rule.id}`} aria-label={`Link to rule ${rule.id}`}>{rule.id}</a>
                              <div class="rule-body">
                                <div class="rule-head">
                                  <strong set:html={rule.title} />
                                  <span class={`severity-pill severity-pill--${rule.severity}`}>
                                    <i class={`fa-solid ${sevIcon[rule.severity]}`}></i>
                                    {sevLabel[rule.severity]}
                                  </span>
                                </div>
                                <p set:html={rule.body} />

                                {rule.display === "strike-pips" && (
                                  <div class="strike-pips">
                                    <div class="strike-pip strike-pip--one">
                                      <span class="strike-pip-num">1</span>
                                      <span class="strike-pip-label">Strike One</span>
                                    </div>
                                    <div class="strike-pip strike-pip--two">
                                      <span class="strike-pip-num">2</span>
                                      <span class="strike-pip-label">Strike Two</span>
                                    </div>
                                    <div class="strike-pip strike-pip--three">
                                      <span class="strike-pip-num">3</span>
                                      <span class="strike-pip-label">Disband</span>
                                    </div>
                                  </div>
                                )}
                              </div>
                            </div>
                          </>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </section>
          ))}

          <!-- Footer CTA -->
          <div class="rules-footer-cta">
            <div class="rules-footer-cta-icon">
              <i class="fa-solid fa-headset"></i>
            </div>
            <div class="rules-footer-cta-text">
              <strong>Questions about the rules?</strong>
              <p>Open a support ticket in Discord and a staff member will clarify any situation.</p>
            </div>
            <a class="button" href="/#apply">Apply Now</a>
          </div>

        </main>
      </div>
    </div>
  </div>
</MainLayout>

<style>
  /* --- Page wrapper --- */
  .rules-page {
    position: relative;
    z-index: 1;
    min-height: calc(100vh - 106px);
  }

  /* --- Page header --- */
  .rules-header {
    position: relative;
    z-index: 1;
    padding: 64px 0 48px;
  }

  .rules-title {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.8rem, 5vw, 4.4rem);
    letter-spacing: -0.06em;
    line-height: 0.98;
    margin: 18px 0 16px;
    color: var(--text);
  }

  .rules-title span {
    color: var(--primary);
    text-shadow: 0 0 40px rgba(0, 174, 255, 0.25);
  }

  .rules-subtitle {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 58ch;
  }

  /* --- Outer container --- */
  .rules-outer {
    position: relative;
    z-index: 1;
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* --- Stats row --- */
  .rules-stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 44px;
  }

  .rules-stat {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(0, 174, 255, 0.06);
    border: 1px solid rgba(0, 174, 255, 0.15);
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    font-size: 0.84rem;
    font-weight: 600;
    color: #8ecfee;
    letter-spacing: 0.01em;
  }

  .rules-stat i {
    color: var(--primary);
    font-size: 0.82rem;
  }

  .rules-stat--warn {
    background: rgba(255, 180, 0, 0.06);
    border-color: rgba(255, 180, 0, 0.18);
    color: #d4a850;
  }

  .rules-stat--warn i {
    color: #f0b429;
  }

  /* --- Shell grid --- */
  .rules-shell {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 0;
    min-height: 70vh;
    align-items: start;
  }

  /* --- Sidebar TOC --- */
  .rules-sidebar {
    position: sticky;
    top: 106px;
    padding: 16px 14px 18px;
    max-height: calc(100vh - 140px);
    overflow-y: auto;
    scrollbar-width: none;
    background:
      linear-gradient(180deg, rgba(8, 22, 34, 0.94), rgba(5, 12, 19, 0.9)),
      radial-gradient(circle at 15% 0%, rgba(0, 174, 255, 0.16), transparent 42%);
    border: 1px solid rgba(0, 174, 255, 0.18);
    border-left: 2px solid rgba(0, 174, 255, 0.45);
    border-radius: 8px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 18px 38px rgba(0, 0, 0, 0.22);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .rules-toc-label {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8ecfee;
    margin-bottom: 14px;
    padding: 0 4px 10px;
    border-bottom: 1px solid rgba(0, 174, 255, 0.14);
  }

  .rules-toc {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .rules-toc-link {
    display: flex;
    align-items: center;
    gap: 9px;
    min-height: 42px;
    padding: 10px 11px;
    border-radius: 8px;
    color: #a6bed2;
    font-size: 0.875rem;
    font-weight: 650;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.055);
    background: rgba(255, 255, 255, 0.025);
    transition: color var(--transition), background var(--transition), border-color var(--transition), box-shadow var(--transition);
  }

  .rules-toc-link:hover {
    color: #f4f8ff;
    background: rgba(0, 174, 255, 0.08);
    border-color: rgba(0, 174, 255, 0.22);
  }

  .rules-toc-link.active {
    color: #f7fbff;
    background: linear-gradient(90deg, rgba(0, 174, 255, 0.2), rgba(0, 174, 255, 0.07));
    border-color: rgba(0, 174, 255, 0.38);
    box-shadow:
      inset 3px 0 0 rgba(0, 174, 255, 0.95),
      0 0 18px rgba(0, 174, 255, 0.12);
    font-weight: 750;
  }

  .rules-toc-icon {
    width: 18px;
    flex-shrink: 0;
    text-align: center;
    color: #6ea8c9;
    font-size: 0.75rem;
    transition: color var(--transition);
  }

  .rules-toc-link:hover .rules-toc-icon,
  .rules-toc-link.active .rules-toc-icon {
    color: var(--primary);
  }

  .rules-toc-num {
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: #73b9dc;
    width: 20px;
    flex-shrink: 0;
    transition: color var(--transition);
  }

  .rules-toc-link:hover .rules-toc-num,
  .rules-toc-link.active .rules-toc-num {
    color: var(--primary);
  }

  /* --- Main content --- */
  .rules-main {
    padding: 0 0 120px 56px;
    min-width: 0;
    border-left: 1px solid rgba(0, 174, 255, 0.07);
  }

  /* --- Global notice --- */
  .rules-notice {
    display: flex;
    gap: 14px;
    padding: 16px 20px;
    border-radius: 12px;
    background: rgba(0, 174, 255, 0.07);
    border: 1px solid rgba(0, 174, 255, 0.18);
    color: #b0dff5;
    font-size: 0.94rem;
    line-height: 1.7;
    margin-bottom: 52px;
  }

  .rules-notice > i {
    color: var(--primary);
    margin-top: 2px;
    flex-shrink: 0;
  }

  .rules-notice strong {
    color: #d4f0ff;
  }

  /* --- Section --- */
  .rules-section {
    margin-bottom: 80px;
    scroll-margin-top: 120px;
  }

  /* ─── Section header: full-width card ─── */
  .rules-section-header {
    position: relative;
    overflow: hidden;
    margin-bottom: 36px;
    padding: 28px 32px;
    background: linear-gradient(135deg, rgba(0, 174, 255, 0.11) 0%, rgba(0, 174, 255, 0.035) 100%);
    border: 1px solid rgba(0, 174, 255, 0.22);
    border-left: 3px solid rgba(0, 174, 255, 0.7);
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 0 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.045),
      0 18px 42px rgba(0, 0, 0, 0.24);
  }

  /* Roleplay Standards — indigo */
  .rules-section-header--standards {
    background: linear-gradient(135deg, rgba(110, 130, 240, 0.12) 0%, rgba(110, 130, 240, 0.035) 100%);
    border-color: rgba(110, 130, 240, 0.24);
    border-left-color: rgba(110, 130, 240, 0.7);
  }

  /* In-Character Conduct — rose */
  .rules-section-header--conduct {
    background: linear-gradient(135deg, rgba(230, 110, 150, 0.12) 0%, rgba(230, 110, 150, 0.035) 100%);
    border-color: rgba(230, 110, 150, 0.26);
    border-left-color: rgba(230, 110, 150, 0.7);
  }

  /* Police & CHS - teal */
  .rules-section-header--police {
    background: linear-gradient(135deg, rgba(0, 210, 200, 0.12) 0%, rgba(0, 174, 255, 0.035) 100%);
    border-color: rgba(0, 210, 200, 0.24);
    border-left-color: rgba(0, 220, 210, 0.75);
  }

  /* Business & Civilian — emerald */
  .rules-section-header--civilian {
    background: linear-gradient(135deg, rgba(50, 200, 120, 0.12) 0%, rgba(50, 200, 120, 0.035) 100%);
    border-color: rgba(50, 200, 120, 0.24);
    border-left-color: rgba(50, 200, 120, 0.7);
  }

  /* Organised Crime — violet */
  .rules-section-header--crime {
    background: linear-gradient(135deg, rgba(160, 80, 220, 0.13) 0%, rgba(160, 80, 220, 0.04) 100%);
    border-color: rgba(160, 80, 220, 0.27);
    border-left-color: rgba(160, 80, 220, 0.7);
  }

  /* Zones — amber */
  .rules-section-header--warn {
    background: linear-gradient(135deg, rgba(255, 180, 0, 0.12) 0%, rgba(255, 180, 0, 0.035) 100%);
    border-color: rgba(255, 180, 0, 0.23);
    border-left-color: rgba(255, 180, 0, 0.7);
  }

  /* Integrity — red */
  .rules-section-header--danger {
    background: linear-gradient(135deg, rgba(220, 60, 60, 0.14) 0%, rgba(220, 60, 60, 0.04) 100%);
    border-color: rgba(220, 60, 60, 0.28);
    border-left-color: rgba(220, 60, 60, 0.75);
  }

  /* Watermark */
  .rules-section-watermark {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-family: "Space Grotesk", sans-serif;
    font-size: 6rem;
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 1;
    color: rgba(0, 174, 255, 0.045);
    pointer-events: none;
    user-select: none;
  }

  .rules-section-header--standards .rules-section-watermark { color: rgba(110, 130, 240, 0.055); }
  .rules-section-header--conduct   .rules-section-watermark { color: rgba(230, 110, 150, 0.06);  }
  .rules-section-header--police    .rules-section-watermark { color: rgba(0, 220, 210, 0.055);   }
  .rules-section-header--civilian  .rules-section-watermark { color: rgba(50, 200, 120, 0.06);   }
  .rules-section-header--crime     .rules-section-watermark { color: rgba(160, 80, 220, 0.06);   }
  .rules-section-header--warn      .rules-section-watermark { color: rgba(255, 180, 0, 0.06);    }
  .rules-section-header--danger    .rules-section-watermark { color: rgba(220, 60, 60, 0.07);    }

  /* Icon + copy row */
  .rules-section-inner {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    position: relative;
    z-index: 1;
  }

  .rules-section-icon-wrap {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 174, 255, 0.1);
    border: 1px solid rgba(0, 174, 255, 0.22);
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    color: var(--primary);
    font-size: 1rem;
    filter: drop-shadow(0 0 8px rgba(0, 174, 255, 0.25));
    margin-top: 2px;
  }

  .rules-section-icon-wrap--standards {
    background: rgba(110, 130, 240, 0.1);
    border-color: rgba(110, 130, 240, 0.26);
    color: #8a9bff;
    filter: drop-shadow(0 0 8px rgba(110, 130, 240, 0.22));
  }

  .rules-section-icon-wrap--conduct {
    background: rgba(230, 110, 150, 0.1);
    border-color: rgba(230, 110, 150, 0.28);
    color: #ee8aa8;
    filter: drop-shadow(0 0 8px rgba(230, 110, 150, 0.22));
  }

  .rules-section-icon-wrap--police {
    background: rgba(0, 220, 210, 0.1);
    border-color: rgba(0, 220, 210, 0.26);
    color: #00dcd2;
    filter: drop-shadow(0 0 8px rgba(0, 220, 210, 0.22));
  }

  .rules-section-icon-wrap--civilian {
    background: rgba(50, 200, 120, 0.1);
    border-color: rgba(50, 200, 120, 0.26);
    color: #4cd68a;
    filter: drop-shadow(0 0 8px rgba(50, 200, 120, 0.22));
  }

  .rules-section-icon-wrap--crime {
    background: rgba(160, 80, 220, 0.1);
    border-color: rgba(160, 80, 220, 0.28);
    color: #c080e8;
    filter: drop-shadow(0 0 8px rgba(160, 80, 220, 0.22));
  }

  .rules-section-icon-wrap--warn {
    background: rgba(255, 180, 0, 0.1);
    border-color: rgba(255, 180, 0, 0.25);
    color: #f0b429;
    filter: drop-shadow(0 0 8px rgba(255, 180, 0, 0.2));
  }

  .rules-section-icon-wrap--danger {
    background: rgba(220, 60, 60, 0.1);
    border-color: rgba(220, 60, 60, 0.28);
    color: #e05a5a;
    filter: drop-shadow(0 0 8px rgba(220, 60, 60, 0.2));
  }

  /* Section badge */
  .rules-section-badge {
    display: inline-block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.65rem;
    font-weight: 800;
