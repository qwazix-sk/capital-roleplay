      padding: 48px 0 36px;
    }

    .rules-stats-row {
      margin-bottom: 32px;
    }

    .rules-shell {
      grid-template-columns: 1fr;
    }

    .rules-sidebar {
      position: static;
      padding: 0 0 32px;
      max-height: none;
      overflow: visible;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .rules-toc-label {
      display: none;
    }

    .rules-toc {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 6px;
    }

    .rules-main {
      padding: 0 0 60px;
      border-left: none;
      border-top: 1px solid rgba(255, 255, 255, 0.07);
      padding-top: 36px;
    }

    .rules-section-header {
      padding: 22px 20px;
    }

