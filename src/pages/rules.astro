---
import MainLayout from "../layouts/MainLayout.astro";

type Severity = "permaban" | "bannable" | "failrp" | "note";

type Rule = {
  id: string;
  title: string;
  body: string;
  severity: Severity;
  display?: "tier-cards" | "strike-pips";
};

type Subsection = {
  id: string;
  label: string;
  rules: Rule[];
};

type Variant =
  | ""
  | "standards"
  | "conduct"
  | "police"
  | "civilian"
  | "crime"
  | "warn"
  | "danger";

type Section = {
  num: string;
  slug: string;
  variant: Variant;
  icon: string;
  title: string;
  description: string;
  tocLabel: string;
  rules?: Rule[];
  subsections?: Subsection[];
};

const sevLabel: Record<Severity, string> = {
  permaban: "Permanent Ban",
  bannable: "Bannable",
  failrp: "FailRP",
  note: "Notice",
};

const sevIcon: Record<Severity, string> = {
  permaban: "fa-ban",
  bannable: "fa-gavel",
  failrp: "fa-circle-exclamation",
  note: "fa-circle-info",
};

const sections: Section[] = [
  {
    num: "01",
