      align-items: flex-start;
      gap: 16px;
    }

    .rules-footer-cta-icon {
      display: none;
    }
  }
</style>

<script>
  const sections = document.querySelectorAll(".rules-section");
  const tocLinks = document.querySelectorAll(".rules-toc-link");

  function updateTOC() {
    let current = "";
    sections.forEach((section) => {
      const rect = (section as HTMLElement).getBoundingClientRect();
      if (rect.top <= 160) current = section.id;
    });
    tocLinks.forEach((link) => {
      link.classList.remove("active");
      if ((link as HTMLAnchorElement).getAttribute("href") === "#" + current) {
        link.classList.add("active");
      }
    });
  }

  window.addEventListener("scroll", updateTOC, { passive: true });
  updateTOC();
</script>
