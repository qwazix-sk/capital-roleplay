---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Applications — Capital Roleplay">

  <section class="apps-hero">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Open Positions</div>
        <h1>Join the team.<br />Shape the city.</h1>
        <p class="lead">
          Capital Roleplay runs on the people behind it. Whether you want to serve the city in uniform,
          run a business, or help build the community as staff — every role matters.
        </p>
      </div>
    </div>
  </section>

  <section class="apps-section">
    <div class="container">
      <div class="apps-list">

        <!-- Staff Application -->
        <a href="/applications/staff" class="app-card app-card--staff">
          <div class="app-card-bg"></div>
          <div class="app-card-overlay"></div>
          <div class="app-card-inner">
            <div class="app-card-top app-card-top--left">
              <div class="app-badge app-badge--gold">
                Staff Team
              </div>
            </div>
            <div class="app-card-top app-card-top--right">
              <div class="app-status app-status--open" aria-label="Status: Open">
                <span class="app-status-key">Status</span>
                <span class="app-status-value">Open</span>
              </div>
            </div>
            <div class="app-card-bottom app-card-bottom--left">
              <h2>Staff Application</h2>
              <p>Join the team that keeps Capital Roleplay running. Moderators, admins, and support staff who shape the community from the inside.</p>
            </div>
            <div class="app-card-bottom app-card-bottom--right">
              <div class="app-cta">
                <span>Apply Now</span>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          </div>
        </a>

        <!-- Vehicle Developer -->
        <a href="/applications/vehicle-dev" class="app-card app-card--vdev">
          <div class="app-card-video">
            <video autoplay muted loop playsinline>
              <source src="https://pub-80ebeb36fdbb49b4966de28f8ce1b7a3.r2.dev/website/lgmods-pd-vehicles-showcase.webm" type="video/webm" />
            </video>
          </div>
          <div class="app-card-overlay"></div>
          <div class="app-card-inner">
            <div class="app-card-top app-card-top--left">
              <div class="app-badge app-badge--purple">
                Vehicle Development
              </div>
            </div>
            <div class="app-card-top app-card-top--right">
              <div class="app-status app-status--open" aria-label="Status: Open">
                <span class="app-status-key">Status</span>
                <span class="app-status-value">Open</span>
              </div>
            </div>
            <div class="app-card-bottom app-card-bottom--left">
              <h2>Vehicle Developer</h2>
              <p>Source, configure, and stream high-quality vehicles into the server. Requires hands-on experience with meta files, FiveM streaming, and vehicle development workflows.</p>
            </div>
            <div class="app-card-bottom app-card-bottom--right">
              <div class="app-cta">
                <span>Apply Now</span>
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M4 10h12M12 5l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <div class="cta-box">
        <div>
          <h3>Not sure where to start?</h3>
          <p>All positions require an active whitelist. Apply for the server first, then come back here.</p>
        </div>
        <a class="button" href="/#apply">Apply for Whitelist</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .apps-hero {
    padding: 90px 0 0;
  }

  .apps-hero h1 {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.8rem, 5vw, 4.4rem);
    line-height: 1.05;
    letter-spacing: -0.05em;
  }

  .apps-section {
    padding: 48px 0 110px;
  }

  /* ── Card list ─────────────────────────────────────────── */
  .apps-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Base card ─────────────────────────────────────────── */
  .app-card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 200px;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.36);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition:
      transform 300ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 300ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 300ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .app-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 32px 72px rgba(0, 0, 0, 0.5);
  }

  /* ── Background layers ─────────────────────────────────── */
  .app-card-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.02) 100%);
  }

  /* Staff */
  .app-card--staff .app-card-bg {
    background:
      linear-gradient(135deg, rgba(10,11,13,0.28) 0%, rgba(10,11,13,0.54) 100%),
      url('https://pub-80ebeb36fdbb49b4966de28f8ce1b7a3.r2.dev/website/capital-staff-applications.png') center / cover no-repeat;
  }
  .app-card--staff {
    min-height: 248px;
  }
  .app-card--staff:hover {
    border-color: rgba(245, 166, 35, 0.32);
    box-shadow: 0 32px 72px rgba(0,0,0,0.5), 0 0 0 1px rgba(245,166,35,0.14);
  }

  /* Vehicle Dev */
  .app-card--vdev {
    position: relative;
  }
  .app-card-video {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    border-radius: 24px;
  }
  .app-card-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.38) saturate(0.7);
  }
  .app-card--vdev .app-card-overlay {
    background-image:
      linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
    background-size: 40px 40px;
    background-color: transparent;
  }
  .app-card--vdev .app-card-inner {
    position: relative;
  }
  .app-card--vdev .app-card-left,
  .app-card--vdev .app-card-right {
    position: relative;
    z-index: 1;
  }
  .app-card--vdev:hover {
    border-color: rgba(168, 85, 247, 0.32);
    box-shadow: 0 32px 72px rgba(0,0,0,0.5), 0 0 0 1px rgba(168,85,247,0.14);
  }

  .app-card-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image:
      linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .app-card-inner {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    grid-template-rows: auto auto;
    align-content: space-between;
    gap: 32px;
    padding: 26px 48px 20px;
  }

  .app-card-top,
  .app-card-bottom {
    display: flex;
    flex-direction: column;
  }

  .app-card-top--left {
    grid-column: 1;
    grid-row: 1;
    align-items: flex-start;
  }

  .app-card-top--right {
    grid-column: 2;
    grid-row: 1;
    align-items: flex-end;
  }

  .app-card-bottom--left {
    grid-column: 1;
    grid-row: 2;
    max-width: 640px;
    gap: 14px;
    align-self: end;
  }

  .app-card-bottom--right {
    grid-column: 2;
    grid-row: 2;
    align-items: flex-end;
    align-self: end;
  }

  .app-card-bottom--left h2 {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0;
  }

  .app-card-bottom--left p {
    color: #9db0c6;
    font-size: 0.97rem;
    line-height: 1.75;
    margin: 0;
  }

  /* ── Badges ────────────────────────────────────────────── */
  .app-badge {
    display: inline-flex;
    align-items: center;
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    width: fit-content;
    backdrop-filter: blur(12px);
  }

  .app-badge--gold  { background: rgba(12,16,21,0.72); border: 1px solid rgba(245,166,35,0.24); color: #f2cb7c; }
  .app-badge--purple { background: rgba(12,16,21,0.72); border: 1px solid rgba(168,85,247,0.24); color: #d6b9ff; }

  /* ── Status pill ───────────────────────────────────────── */
  .app-status {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px;
    border-radius: 999px;
    background: rgba(9, 14, 22, 0.76);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
  }

  .app-status-key,
  .app-status-value {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .app-status-key {
    color: #7f93a8;
    background: rgba(255, 255, 255, 0.03);
    font-weight: 600;
  }

  .app-status-value {
    font-weight: 700;
  }

  .app-status--open .app-status-value {
    color: #b9e7c6;
    background: rgba(35, 111, 72, 0.34);
  }

  .app-status--hold .app-status-value {
    color: #f2cf89;
    background: rgba(112, 83, 29, 0.34);
  }

  .app-status--closed .app-status-value {
    color: #f0b1b1;
    background: rgba(110, 42, 42, 0.34);
  }

  /* ── CTA ───────────────────────────────────────────────── */
  .app-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 0.94rem;
    font-weight: 600;
    color: #f4f8ff;
    transition: gap 240ms ease;
  }

  .app-card:hover .app-cta {
    gap: 14px;
  }

  @media (max-width: 720px) {
    .app-card-inner {
      position: relative;
      inset: auto;
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto auto;
      align-content: start;
      padding: 24px 24px 20px;
      gap: 18px;
    }

    .app-card-top--left,
    .app-card-top--right,
    .app-card-bottom--left,
    .app-card-bottom--right {
      grid-column: 1;
    }

    .app-card-top--left { grid-row: 1; }
    .app-card-top--right {
      grid-row: 2;
      align-items: flex-start;
    }
    .app-card-bottom--left { grid-row: 3; }
    .app-card-bottom--right { grid-row: 4; align-items: flex-start; }
  }
</style>
