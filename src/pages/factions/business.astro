---
import FactionHub from "../../components/FactionHub.astro";

const cards = [
  {
    id: "businesses",
    badge: "Commerce & Retail",
    eyebrow: "Track 01",
    title: "Businesses",
    description:
      "Retail storefronts, hospitality venues, and service operators that give the city a public economy and a place for day-to-day roleplay to live.",
    icon: "briefcase",
    departments: ["Retail", "Hospitality", "Nightlife", "Service Venues"],
    ctaLabel: "Work in Progress",
  },
  {
    id: "media",
    badge: "Public Presence",
    eyebrow: "Track 02",
    title: "Media & Events",
    description:
      "News outlets, creators, promoters, and organisers who shape the city's public image, social calendar, and civilian spotlight moments.",
    icon: "broadcast",
    departments: ["Media", "Events", "Promotion", "Branding"],
    ctaLabel: "Work in Progress",
  },
  {
    id: "community",
    badge: "Community Layer",
    eyebrow: "Track 03",
    title: "Civilian Organisations",
    description:
      "Clubs, charities, social groups, and resident networks that turn ordinary characters into long-running communities and stories.",
    icon: "users",
    departments: ["Clubs", "Charities", "Communities", "Networks"],
    ctaLabel: "Work in Progress",
  },
];
---

<FactionHub
  pageTitle="Business & Civilian Groups - Capital Roleplay"
  badge="Civilian Life Division"
  titleLines={["Business & Civilian", "Groups."]}
  lead="The civilian layer of Capital Roleplay. Player-run business, public-facing media, and community-driven organisations that make the city feel lived in."
  indexLabel="WIP"
  footerLabel="WIP"
  dividerLabel="WIP"
  dividerMeta="3 / 3"
  stats={[
    { value: "03", label: "Sections" },
    { value: "Player-led", label: "Direction" },
  ]}
  cards={cards}
  heroBackground="radial-gradient(ellipse 60% 80% at 8% 20%, rgba(245, 166, 35, 0.28) 0%, transparent 60%), radial-gradient(ellipse 50% 60% at 92% 78%, rgba(190, 120, 20, 0.16) 0%, transparent 60%), radial-gradient(ellipse 40% 50% at 60% 8%, rgba(255, 220, 150, 0.10) 0%, transparent 55%), linear-gradient(160deg, #130f04 0%, #1e1505 40%, #261a06 75%, #110d03 100%)"
  cardBackground="radial-gradient(circle at 28% 30%, rgba(245, 200, 110, 0.42) 0%, transparent 55%), radial-gradient(circle at 78% 76%, rgba(245, 166, 35, 0.30) 0%, transparent 52%), linear-gradient(140deg, #2a1f08 0%, #3d2f10 50%, #1a1306 100%)"
  cardGlow="radial-gradient(circle at 50% 55%, rgba(255,255,255,0.12) 0%, transparent 60%)"
  accentColor="#f5a623"
  accentSoft="#f5c96a"
  accentBorder="rgba(245,166,35,0.28)"
  iconColor="#f5d28a"
  ctaTitle="Build something in the city."
  ctaBody="Get whitelisted first, then bring your business concept to the Discord for review."
  showCards={false}
  wipBox={{
    label: "Work in Progress",
    title: "WIP",
    body: "Business listings, media pathways, and civilian organisation details are still being prepared for launch.",
  }}
/>
