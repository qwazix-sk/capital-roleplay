---
import FactionHub from "../../components/FactionHub.astro";

const cards = [
  {
    id: "crews",
    badge: "Street Presence",
    eyebrow: "Track 01",
    title: "Crews & Gangs",
    description:
      "Street-level groups built around territory, identity, and local influence. The visible edge of the criminal ecosystem inside the city.",
    icon: "mask",
    departments: ["Street Sets", "Corners", "Territory", "Reputation"],
    ctaLabel: "Work in Progress",
  },
  {
    id: "operations",
    badge: "Structured Operations",
    eyebrow: "Track 02",
    title: "Organised Crews",
    description:
      "More coordinated criminal structures handling supply, transport, planning, and higher-stakes operations behind a cleaner public front.",
    icon: "network",
    departments: ["Heists", "Logistics", "Protection", "Supply Lines"],
    ctaLabel: "Work in Progress",
  },
  {
    id: "market",
    badge: "Shadow Economy",
    eyebrow: "Track 03",
    title: "Black Market",
    description:
      "The hidden economy built on fences, forged identities, illicit trade, and the systems that keep illegal commerce moving out of sight.",
    icon: "vault",
    departments: ["Forgery", "Fences", "Trafficking", "Arms Trade"],
    ctaLabel: "Work in Progress",
  },
];
---

<FactionHub
  pageTitle="Organised Crime - Capital Roleplay"
  badge="Underground Division"
  titleLines={["Organised", "Crime."]}
  lead="The underworld layer of Capital Roleplay. Criminal crews, hidden operations, and black-market structures built for long-form illegal roleplay."
  indexLabel="WIP"
  footerLabel="WIP"
  dividerLabel="WIP"
  dividerMeta="3 / 3"
  stats={[
    { value: "03", label: "Sections" },
    { value: "High Risk", label: "Profile" },
  ]}
  cards={cards}
  heroBackground="radial-gradient(ellipse 60% 80% at 8% 20%, rgba(220, 38, 68, 0.30) 0%, transparent 60%), radial-gradient(ellipse 50% 60% at 92% 78%, rgba(150, 20, 40, 0.18) 0%, transparent 60%), radial-gradient(ellipse 40% 50% at 60% 8%, rgba(255, 120, 150, 0.10) 0%, transparent 55%), linear-gradient(160deg, #130408 0%, #1e060c 40%, #28080f 75%, #110305 100%)"
  cardBackground="radial-gradient(circle at 25% 30%, rgba(255, 80, 110, 0.42) 0%, transparent 55%), radial-gradient(circle at 80% 76%, rgba(220, 38, 68, 0.30) 0%, transparent 52%), linear-gradient(140deg, #2a0a14 0%, #401421 50%, #1a0810 100%)"
  cardGlow="radial-gradient(circle at 50% 55%, rgba(255,255,255,0.10) 0%, transparent 60%)"
  accentColor="#dc2644"
  accentSoft="#ff7a95"
  accentBorder="rgba(220,38,68,0.28)"
  iconColor="#ffb3c2"
  ctaTitle="Every empire starts somewhere."
  ctaBody="Get whitelisted, establish your character, and bring your criminal concept to the Discord for consideration."
  showCards={false}
  wipBox={{
    label: "Work in Progress",
    title: "WIP",
    body: "Crime faction structure, requirements, and concept guidance are still being prepared for release.",
  }}
/>
