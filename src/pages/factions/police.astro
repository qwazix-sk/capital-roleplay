---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Police & Emergency Services — Capital Roleplay">

  <section class="subfaction-hero subfaction-police">
    <div class="subfaction-hero-bg"></div>
    <div class="subfaction-hero-noise"></div>
    <div class="subfaction-hero-overlay"></div>
    <div class="container subfaction-hero-inner">
      <a href="/factions" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.25 8H3.75M3.75 8L7.25 4.5M3.75 8L7.25 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All Factions
      </a>
      <div class="subfaction-badge subfaction-badge--blue">Law &amp; Order</div>
      <h1>Police &amp; Emergency Services</h1>
      <p>
        Law enforcement, medical response, and fire service roleplay. The structured backbone
        of Capital Roleplay's civil order.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="subfaction-grid">

        <div class="subfaction-panel">
          <div class="subfaction-icon subfaction-icon--blue">⬡</div>
          <h3>Overview</h3>
          <p>
            The Police &amp; Emergency Services faction covers all law enforcement, medical, and
            fire response roleplay on the server. This faction is reserved for players who want
            to serve the city in a structured, serious capacity.
          </p>
          <p style="margin-top: 14px;">
            Information about specific departments, hierarchy, uniforms, and vehicles will be
            populated here as the server develops.
          </p>
        </div>

        <div class="subfaction-panel">
          <div class="subfaction-icon subfaction-icon--blue">◉</div>
          <h3>Recruitment</h3>
          <p>
            Recruitment for emergency services will open through the Discord. Details around
            applications, interview processes, and training structure will be listed here.
          </p>
          <ul class="subfaction-list subfaction-list--blue">
            <li>Whitelist required before applying to any department</li>
            <li>Applications reviewed by faction leadership</li>
            <li>Structured training period before full deployment</li>
          </ul>
        </div>

        <div class="subfaction-panel subfaction-panel--wide">
          <div class="subfaction-icon subfaction-icon--blue">✦</div>
          <h3>Departments</h3>
          <p>This section will outline the active departments within the emergency services faction once the server is live. Placeholder structure below.</p>
          <div class="dept-grid">
            <div class="dept-card dept-card--blue">
              <strong>Metropolitan Police</strong>
              <span>Patrol, response, and detective operations within the city.</span>
            </div>
            <div class="dept-card dept-card--blue">
              <strong>Emergency Medical Services</strong>
              <span>Medical response, trauma care, and hospital roleplay.</span>
            </div>
            <div class="dept-card dept-card--blue">
              <strong>Fire &amp; Rescue</strong>
              <span>Structural fire response and rescue operations.</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <div>
          <h3>Ready to serve the city?</h3>
          <p>Get whitelisted first, then apply for a department through Discord once recruitment opens.</p>
        </div>
        <a class="button" href="/#apply">Apply for Whitelist</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────── */
  .subfaction-hero {
    position: relative;
    min-height: 420px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 0;
    overflow: hidden;
  }

  .subfaction-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .subfaction-police .subfaction-hero-bg {
    background:
      radial-gradient(circle at 20% 30%, rgba(0, 174, 255, 0.32) 0%, transparent 52%),
      radial-gradient(circle at 80% 70%, rgba(0, 90, 180, 0.24) 0%, transparent 44%),
      linear-gradient(160deg, #050d1a 0%, #071425 40%, #061933 75%, #040e1f 100%);
  }

  .subfaction-hero-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(circle at 30% 40%, black 20%, transparent 75%);
    opacity: 0.4;
  }

  .subfaction-hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(4, 10, 18, 0.3) 60%,
      rgba(4, 10, 18, 0.9) 100%
    );
  }

  .subfaction-hero-inner {
    position: relative;
    z-index: 3;
    padding-top: 100px;
    padding-bottom: 72px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .subfaction-hero-inner h1 {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.05em;
    max-width: 18ch;
  }

  .subfaction-hero-inner p {
    color: #9db0c6;
    font-size: 1.05rem;
    line-height: 1.78;
    max-width: 56ch;
  }

  /* ── Back link ────────────────────────────────────────── */
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #9db0c6;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 220ms ease;
  }

  .back-link:hover {
    color: #f4f8ff;
  }

  /* ── Faction badge ────────────────────────────────────── */
  .subfaction-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .subfaction-badge::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .subfaction-badge--blue {
    background: rgba(0, 174, 255, 0.12);
    border: 1px solid rgba(0, 174, 255, 0.26);
    color: #79d6ff;
  }
  .subfaction-badge--blue::before {
    background: #00aeff;
    box-shadow: 0 0 12px rgba(0, 174, 255, 0.5);
  }

  /* ── Content grid ─────────────────────────────────────── */
  .subfaction-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .subfaction-panel {
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.025));
    padding: 28px;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.28);
  }

  .subfaction-panel h3 {
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.2rem;
    margin-bottom: 12px;
  }

  .subfaction-panel p {
    color: #9db0c6;
    line-height: 1.8;
    font-size: 0.97rem;
  }

  .subfaction-panel--wide {
    grid-column: 1 / -1;
  }

  /* ── Icon ─────────────────────────────────────────────── */
  .subfaction-icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    font-size: 1rem;
    margin-bottom: 18px;
  }

  .subfaction-icon--blue {
    background: rgba(0, 174, 255, 0.1);
    border: 1px solid rgba(0, 174, 255, 0.18);
    color: #9ee5ff;
  }

  /* ── List ─────────────────────────────────────────────── */
  .subfaction-list {
    list-style: none;
    display: grid;
    gap: 10px;
    margin-top: 18px;
  }

  .subfaction-list li {
    display: flex;
    gap: 10px;
    color: #c8d5e3;
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .subfaction-list--blue li::before {
    content: "•";
    color: #00aeff;
    font-size: 1.1rem;
    line-height: 1;
    margin-top: 2px;
    flex-shrink: 0;
  }

  /* ── Dept cards ───────────────────────────────────────── */
  .dept-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-top: 22px;
  }

  .dept-card {
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    padding: 18px;
  }

  .dept-card strong {
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 0.98rem;
    margin-bottom: 8px;
  }

  .dept-card span {
    color: #9db0c6;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .dept-card--blue {
    border-color: rgba(0, 174, 255, 0.12);
  }

  @media (max-width: 860px) {
    .subfaction-grid {
      grid-template-columns: 1fr;
    }

    .subfaction-panel--wide {
      grid-column: 1;
    }

    .dept-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
