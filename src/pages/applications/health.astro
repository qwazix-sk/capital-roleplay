---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout title="Capital Health Service — Capital Roleplay">

  <section class="app-sub-hero app-sub-hero--health">
    <div class="app-sub-hero-bg"></div>
    <div class="app-sub-hero-noise"></div>
    <div class="app-sub-hero-overlay"></div>
    <div class="container app-sub-hero-inner">
      <a href="/applications" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M12.25 8H3.75M3.75 8L7.25 4.5M3.75 8L7.25 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All Applications
      </a>
      <div class="app-sub-badge app-sub-badge--green">
        <span></span>
        Medical Service
      </div>
      <h1>Capital Health Service</h1>
      <p>Emergency medical response, hospital roleplay, and frontline healthcare. The lifeline of the city's civilian infrastructure.</p>
    </div>
  </section>

  <section class="section wip-section">
    <div class="container">
      <div class="wip-block wip-block--green">
        <div class="wip-label">Work in progress</div>
        <div class="wip-text">WIP</div>
        <p class="wip-sub">The Capital Health Service application is being built. Full details on paramedic, hospital, and specialist roles will be published here before recruitment opens.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <div>
          <h3>Get whitelisted first.</h3>
          <p>All department applications require an active whitelist. Apply for the server first, then return when recruitment opens.</p>
        </div>
        <a class="button" href="/#apply">Apply for Whitelist</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .app-sub-hero {
    position: relative;
    min-height: 500px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    margin-top: -120px;
    z-index: 0;
  }

  .app-sub-hero-bg { position: absolute; inset: 0; z-index: 0; }

  .app-sub-hero--health .app-sub-hero-bg {
    background:
      radial-gradient(circle at 20% 30%, rgba(34, 197, 94, 0.22) 0%, transparent 52%),
      radial-gradient(circle at 80% 70%, rgba(16, 120, 50, 0.18) 0%, transparent 44%),
      linear-gradient(160deg, #030f08 0%, #061a0e 40%, #041408 75%, #020c05 100%);
  }

  .app-sub-hero-noise {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(to bottom,
        rgba(4,10,17,0.42) 0%,
        rgba(4,10,17,0.10) 18%,
        rgba(4,10,17,0.0)  40%,
        rgba(4,10,17,0.0)  55%,
        rgba(4,10,17,0.88) 84%,
        rgba(6,10,17,1.0)  100%
      );
  }

  .app-sub-hero-overlay {
    position: absolute; inset: 0; z-index: 2;
    background:
      radial-gradient(ellipse at 15% 85%, rgba(34,197,94,0.10) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 15%, rgba(16,120,50,0.07) 0%, transparent 45%);
  }

  .app-sub-hero-inner {
    position: relative; z-index: 3;
    padding-top: 190px; padding-bottom: 80px;
    display: flex; flex-direction: column; gap: 18px;
  }

  .app-sub-hero-inner h1 {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1; letter-spacing: -0.05em; max-width: 20ch;
  }

  .app-sub-hero-inner p { color: #9db0c6; font-size: 1.05rem; line-height: 1.78; max-width: 56ch; }

  .back-link {
    display: inline-flex; align-items: center; gap: 8px;
    color: #9db0c6; font-size: 0.9rem; font-weight: 600;
    text-decoration: none; transition: color 220ms ease;
  }
  .back-link:hover { color: #f4f8ff; }

  .app-sub-badge {
    display: inline-flex; align-items: center; gap: 8px;
    align-self: flex-start; padding: 5px 14px; border-radius: 999px;
    font-size: 0.74rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .app-sub-badge span { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .app-sub-badge--green { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.24); color: #86efac; }
  .app-sub-badge--green span { background: #22c55e; box-shadow: 0 0 12px rgba(34,197,94,0.5); }

  .wip-section { padding-bottom: 0; }
  .wip-block {
    border-radius: 28px; border: 1px solid rgba(255,255,255,0.08);
    background: linear-gradient(160deg, rgba(255,255,255,0.04), rgba(255,255,255,0.02));
    padding: 80px 40px; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 20px;
  }
  .wip-label { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; opacity: 0.5; }
  .wip-text {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(6rem, 18vw, 14rem);
    font-weight: 700; letter-spacing: -0.06em; line-height: 1; opacity: 0.18;
  }
  .wip-block--green .wip-text { color: #22c55e; }
  .wip-sub { color: #9db0c6; font-size: 1rem; line-height: 1.75; max-width: 52ch; margin-top: -8px; }
</style>
