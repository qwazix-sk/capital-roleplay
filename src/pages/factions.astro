---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Factions — Capital Roleplay">

  <section class="factions-hero">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Faction structure</div>
        <h1>Every faction. One city.</h1>
        <p class="lead">
          Capital Roleplay runs on three pillars of faction roleplay. Whether you wear a badge,
          run a business, or operate in the shadows — your path starts here.
        </p>
      </div>
    </div>
  </section>

  <section class="factions-section">
    <div class="container">
      <div class="faction-grid">

        <!-- Police & Emergency Services -->
        <a href="/factions/police" class="faction-card faction-police">
          <div class="faction-card-bg"></div>
          <div class="faction-card-noise"></div>
          <div class="faction-card-overlay"></div>
          <div class="faction-card-inner">
            <div class="faction-badge faction-badge--blue">Law &amp; Order</div>
            <div class="faction-card-body">
              <h2>Police &amp; Emergency Services</h2>
              <p>Law enforcement, medical response, and emergency services. The backbone of the city's structure.</p>
              <div class="faction-cta">
                <span>Explore Faction</span>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </div>
        </a>

        <!-- Business & Civilian Groups -->
        <a href="/factions/business" class="faction-card faction-business">
          <div class="faction-card-bg"></div>
          <div class="faction-card-noise"></div>
          <div class="faction-card-overlay"></div>
          <div class="faction-card-inner">
            <div class="faction-badge faction-badge--gold">Civilian Life</div>
            <div class="faction-card-body">
              <h2>Business &amp; Civilian Groups</h2>
              <p>Player-run businesses, media houses, and civilian organisations shaping the social fabric of the city.</p>
              <div class="faction-cta">
                <span>Explore Faction</span>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </div>
        </a>

        <!-- Organised Crime -->
        <a href="/factions/crime" class="faction-card faction-crime">
          <div class="faction-card-bg"></div>
          <div class="faction-card-noise"></div>
          <div class="faction-card-overlay"></div>
          <div class="faction-card-inner">
            <div class="faction-badge faction-badge--red">Underground</div>
            <div class="faction-card-body">
              <h2>Organised Crime</h2>
              <p>Illegal faction frameworks, criminal enterprises, and structured underworld operations beneath the surface.</p>
              <div class="faction-cta">
                <span>Explore Faction</span>
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M3.75 9H14.25M14.25 9L9.75 4.5M14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <section class="factions-note section">
    <div class="container">
      <div class="cta-box">
        <div>
          <h3>Pick your side. Build your story.</h3>
          <p>
            Faction roleplay in Capital Roleplay is built around structure, standards, and long-term progression.
            Every group has a purpose and every role has weight.
          </p>
        </div>
        <a class="button" href="/#apply">Apply for Whitelist</a>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .factions-hero {
    padding: 90px 0 0;
  }

  .factions-section {
    padding: 48px 0 110px;
  }

  /* ── Faction grid ───────────────────────────────────────── */
  .faction-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ── Base card ──────────────────────────────────────────── */
  .faction-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 520px;
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.38);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition:
      transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .faction-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 36px 80px rgba(0, 0, 0, 0.48);
  }

  /* ── Placeholder backgrounds ────────────────────────────── */
  .faction-card-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* Police: photo background */
  .faction-police .faction-card-bg {
    background-image: url('https://pub-80ebeb36fdbb49b4966de28f8ce1b7a3.r2.dev/website/police-placeholder.png');
    background-size: cover;
    background-position: center top;
  }

  .faction-police:hover {
    border-color: rgba(0, 174, 255, 0.38);
    box-shadow: 0 36px 80px rgba(0, 0, 0, 0.48), 0 0 0 1px rgba(0, 174, 255, 0.18);
  }

  /* Business: warm amber / gold */
  .faction-business .faction-card-bg {
    background:
      radial-gradient(circle at 70% 25%, rgba(245, 166, 35, 0.2) 0%, transparent 50%),
      radial-gradient(circle at 25% 70%, rgba(200, 120, 0, 0.16) 0%, transparent 45%),
      linear-gradient(160deg, #130f04 0%, #1e1505 40%, #261a06 75%, #110d03 100%);
  }

  .faction-business:hover {
    border-color: rgba(245, 166, 35, 0.36);
    box-shadow: 0 36px 80px rgba(0, 0, 0, 0.48), 0 0 0 1px rgba(245, 166, 35, 0.16);
  }

  /* Crime: deep crimson / smoke */
  .faction-crime .faction-card-bg {
    background:
      radial-gradient(circle at 60% 30%, rgba(220, 38, 68, 0.22) 0%, transparent 50%),
      radial-gradient(circle at 20% 72%, rgba(160, 20, 40, 0.18) 0%, transparent 45%),
      linear-gradient(160deg, #130408 0%, #1e060c 40%, #28080f 75%, #110305 100%);
  }

  .faction-crime:hover {
    border-color: rgba(220, 38, 68, 0.36);
    box-shadow: 0 36px 80px rgba(0, 0, 0, 0.48), 0 0 0 1px rgba(220, 38, 68, 0.16);
  }

  /* ── Dot-grid texture ───────────────────────────────────── */
  .faction-card-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size: 36px 36px;
    mask-image: radial-gradient(circle at center, black 30%, transparent 85%);
    opacity: 0.5;
  }

  /* ── Bottom gradient overlay ────────────────────────────── */
  .faction-card-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      to top,
      rgba(4, 10, 18, 0.96) 0%,
      rgba(4, 10, 18, 0.72) 34%,
      rgba(4, 10, 18, 0.14) 65%,
      transparent 100%
    );
    transition: background 320ms ease;
  }

  .faction-card:hover .faction-card-overlay {
    background: linear-gradient(
      to top,
      rgba(4, 10, 18, 0.98) 0%,
      rgba(4, 10, 18, 0.8) 38%,
      rgba(4, 10, 18, 0.22) 68%,
      transparent 100%
    );
  }

  /* ── Card content ───────────────────────────────────────── */
  .faction-card-inner {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: 28px;
  }

  .faction-card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .faction-card-inner h2 {
    font-family: "Space Grotesk", sans-serif;
    font-size: clamp(1.45rem, 2.2vw, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #f4f8ff;
  }

  .faction-card-inner p {
    color: #9db0c6;
    font-size: 0.96rem;
    line-height: 1.75;
    max-width: 30ch;
  }

  /* ── Category badge ─────────────────────────────────────── */
  .faction-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    align-self: flex-start;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 999px;
    font-size: 0.73rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .faction-badge::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .faction-badge--blue {
    background: rgba(0, 174, 255, 0.12);
    border: 1px solid rgba(0, 174, 255, 0.26);
    color: #79d6ff;
  }
  .faction-badge--blue::before {
    background: #00aeff;
    box-shadow: 0 0 12px rgba(0, 174, 255, 0.5);
  }

  .faction-badge--gold {
    background: rgba(245, 166, 35, 0.1);
    border: 1px solid rgba(245, 166, 35, 0.24);
    color: #f5c96a;
  }
  .faction-badge--gold::before {
    background: #f5a623;
    box-shadow: 0 0 12px rgba(245, 166, 35, 0.5);
  }

  .faction-badge--red {
    background: rgba(220, 38, 68, 0.1);
    border: 1px solid rgba(220, 38, 68, 0.24);
    color: #ff7a95;
  }
  .faction-badge--red::before {
    background: #dc2644;
    box-shadow: 0 0 12px rgba(220, 38, 68, 0.5);
  }

  /* ── Explore CTA ────────────────────────────────────────── */
  .faction-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 6px;
    font-size: 0.9rem;
    font-weight: 700;
    color: rgba(244, 248, 255, 0.5);
    transition: color 280ms ease, gap 280ms ease;
  }

  .faction-card:hover .faction-cta {
    gap: 12px;
  }

  .faction-police:hover .faction-cta  { color: #7ed9ff; }
  .faction-business:hover .faction-cta { color: #f5c96a; }
  .faction-crime:hover .faction-cta   { color: #ff7a95; }

  /* ── Responsive ─────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .faction-grid {
      grid-template-columns: 1fr;
      max-width: 640px;
    }

    .faction-card {
      min-height: 420px;
    }

    .faction-card-inner p {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .factions-section {
      padding-bottom: 80px;
    }

    .faction-card {
      min-height: 360px;
    }
  }
</style>
