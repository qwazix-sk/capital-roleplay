---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Factions — Capital Roleplay">
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Faction structure</div>
        <h1>Faction roleplay with structure.</h1>
        <p class="lead">
          This page should later become the central overview for legal and illegal factions in Capital Roleplay.
          For now, it establishes the visual structure and navigation.
        </p>
      </div>

      <div class="cards">
        <article class="card">
          <h3>Police & Emergency Services</h3>
          <p>
            Reserved for law enforcement, medical, and public service faction information,
            recruitment, expectations, and progression.
          </p>
        </article>

        <article class="card">
          <h3>Business & Civilian Groups</h3>
          <p>
            Reserved for player-run businesses, civilian organisations, and other structured
            community roleplay groups.
          </p>
        </article>

        <article class="card">
          <h3>Organised Crime</h3>
          <p>
            Reserved for illegal faction framework, standards, recruitment requirements,
            and progression inside the city.
          </p>
        </article>
      </div>
    </div>
  </section>
</MainLayout>