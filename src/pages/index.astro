          grid-template-columns: 1fr;
        }

        .panel-float,
        .panel-logo,
        .panel-main {
          position: relative;
          inset: auto;
          width: 100%;
          max-width: none;
        }

        .hero-panel {
          display: grid;
          gap: 16px;
          min-height: auto;
        }

        .cta-box,
        .footer-inner,
        .form-footer,
        .form-locked {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      @media (max-width: 640px) {
        .hero-copy h1 {
          max-width: none;
        }

        .hero-actions,
        .hero-actions .button {
