                <form>
                  <div class="form-grid">
                    <div class="field">
                      <label for="fullname">Full Name</label>
                      <input id="fullname" type="text" placeholder="John Smith" />
                    </div>

                    <div class="field">
                      <label for="discord">Discord Username</label>
                      <input id="discord" type="text" placeholder="username" />
                    </div>

                    <div class="field">
                      <label for="age">Age</label>
                      <select id="age">
                        <option>Select your age range</option>
                        <option>16–17</option>
                        <option>18–20</option>
                        <option>21–25</option>
                        <option>26+</option>
                      </select>
