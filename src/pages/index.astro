---
const storeUrl = "https://your-tebex-store-link.tebex.io";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Capital Roleplay — Serious UK FiveM Roleplay</title>
    <meta
      name="description"
      content="Capital Roleplay is a serious whitelisted FiveM roleplay server based in the United Kingdom, built around custom assets, premium systems, and immersive storytelling."
    />

    <style>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap');

      :root {
        --bg: #061019;
        --bg-soft: #0b1624;
        --panel: rgba(255, 255, 255, 0.045);
        --border: rgba(255, 255, 255, 0.09);
        --text: #f4f8ff;
        --muted: #9db0c6;
        --muted-strong: #c4d2e3;
        --primary: #00aeff;
        --primary-soft: rgba(0, 174, 255, 0.16);
        --primary-glow: rgba(0, 174, 255, 0.34);
        --shadow: 0 10px 40px rgba(0, 0, 0, 0.34);
        --radius: 24px;
        --radius-sm: 18px;
        --max: 1200px;
        --transition: 280ms cubic-bezier(.2,.8,.2,1);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Inter", sans-serif;
        background:
          radial-gradient(circle at 15% 15%, rgba(0, 174, 255, 0.14), transparent 22%),
          radial-gradient(circle at 85% 10%, rgba(0, 174, 255, 0.1), transparent 18%),
          radial-gradient(circle at 50% 100%, rgba(0, 174, 255, 0.08), transparent 30%),
          linear-gradient(180deg, #07111a 0%, #050b12 100%);
        color: var(--text);
        min-height: 100vh;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background:
          linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
        background-size: 44px 44px;
        mask-image: radial-gradient(circle at center, black 40%, transparent 90%);
        opacity: 0.22;
        pointer-events: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(var(--max), calc(100% - 32px));
        margin: 0 auto;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        min-height: 36px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(0, 174, 255, 0.26);
        background: rgba(0, 174, 255, 0.08);
        color: #7fd8ff;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .eyebrow::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--primary);
        box-shadow: 0 0 18px var(--primary-glow);
      }

      .section {
        padding: 110px 0;
        position: relative;
      }

      .section-header {
        max-width: 740px;
        margin-bottom: 34px;
      }

      .section-header h2 {
        font-family: "Space Grotesk", sans-serif;
        font-size: clamp(2rem, 3.4vw, 3.2rem);
        line-height: 1.02;
        letter-spacing: -0.04em;
        margin: 18px 0 14px;
      }

      .section-header p {
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.75;
      }

      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 700ms cubic-bezier(.2,.8,.2,1),
          transform 700ms cubic-bezier(.2,.8,.2,1);
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .site-nav-wrap {
        position: sticky;
        top: 0;
        z-index: 50;
        padding-top: 16px;
      }

      .site-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        min-height: 74px;
        padding: 12px 18px;
        border-radius: 22px;
        background: rgba(6, 16, 25, 0.58);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.2);
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
        min-width: 0;
      }

      .brand-mark,
      .footer-mark,
      .hero-logo-circle,
      .discord-logo-circle {
        border-radius: 999px;
        overflow: hidden;
        flex-shrink: 0;
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 0 0 6px rgba(255,255,255,0.02), 0 0 30px rgba(0,174,255,0.12);
      }

      .brand-mark {
        width: 44px;
        height: 44px;
      }

      .footer-mark {
        width: 28px;
        height: 28px;
      }

      .hero-logo-circle {
        width: 120px;
        height: 120px;
        margin: 0 auto;
      }

      .discord-logo-circle {
        width: 58px;
        height: 58px;
      }

      .brand-mark img,
      .footer-mark img,
      .hero-logo-circle img,
      .discord-logo-circle img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .brand-copy strong {
        display: block;
        font-family: "Space Grotesk", sans-serif;
        font-size: 1rem;
        line-height: 1;
      }

      .brand-copy span {
        display: block;
        margin-top: 6px;
        color: var(--muted);
        font-size: 0.78rem;
        line-height: 1;
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 8px;
        list-style: none;
      }

      .nav-links a {
        color: var(--muted);
        font-size: 0.94rem;
        font-weight: 600;
        padding: 10px 14px;
        border-radius: 12px;
        transition: color var(--transition), background var(--transition);
      }

      .nav-links a:hover {
        color: var(--text);
        background: rgba(255, 255, 255, 0.045);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        padding: 0 22px;
        border-radius: 14px;
        border: 1px solid rgba(0, 174, 255, 0.28);
        background: linear-gradient(180deg, rgba(0, 174, 255, 0.22), rgba(0, 174, 255, 0.12));
        color: #f7fbff;
        font-weight: 700;
        font-size: 0.95rem;
        transition:
          transform var(--transition),
          border-color var(--transition),
          box-shadow var(--transition),
          background var(--transition);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.08),
          0 10px 26px rgba(0, 174, 255, 0.12);
      }

      .button:hover {
        transform: translateY(-2px);
        border-color: rgba(0, 174, 255, 0.48);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.1),
          0 16px 34px rgba(0, 174, 255, 0.18);
      }

      .button.ghost {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.1);
        color: var(--text);
        box-shadow: none;
      }

      .button.discord {
        background: linear-gradient(180deg, rgba(88, 101, 242, 0.3), rgba(88, 101, 242, 0.18));
        border-color: rgba(88, 101, 242, 0.38);
        box-shadow: 0 12px 28px rgba(88, 101, 242, 0.18);
      }

      .button.small {
        min-height: 44px;
        padding: 0 16px;
        font-size: 0.9rem;
      }

      .hero {
        padding: 76px 0 42px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 28px;
        align-items: center;
      }

      .hero-copy h1 {
        font-family: "Space Grotesk", sans-serif;
        font-size: clamp(3.2rem, 8vw, 6.2rem);
        line-height: 0.95;
        letter-spacing: -0.06em;
        margin: 22px 0 22px;
        max-width: 11ch;
      }

      .hero-copy h1 span {
        color: var(--primary);
        text-shadow: 0 0 26px rgba(0, 174, 255, 0.2);
      }

      .hero-copy p {
        max-width: 640px;
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.8;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 30px;
      }

      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-top: 30px;
      }

      .meta-chip {
        min-height: 42px;
        padding: 0 14px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.035);
        color: var(--muted-strong);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.88rem;
        font-weight: 600;
      }

      .meta-chip::before {
        content: "";
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--primary);
        box-shadow: 0 0 14px var(--primary-glow);
      }

      .hero-panel {
        position: relative;
        min-height: 520px;
        border-radius: 32px;
        padding: 24px;
        background: linear-gradient(180deg, rgba(255,255,255,0.05), rgba(255,255,255,0.025));
        border: 1px solid rgba(255,255,255,0.08);
        overflow: hidden;
        box-shadow: var(--shadow);
      }

      .hero-panel::before {
        content: "";
        position: absolute;
        inset: auto -10% -30% auto;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(0,174,255,0.35), transparent 68%);
        filter: blur(24px);
      }

      .hero-panel::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 24px 24px;
        opacity: 0.22;
        mask-image: radial-gradient(circle at center, black 46%, transparent 88%);
        pointer-events: none;
      }

      .panel-card {
        position: absolute;
        border-radius: 22px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(8, 18, 28, 0.82);
        backdrop-filter: blur(16px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.26);
      }

      .panel-logo {
        top: 26px;
        right: 26px;
        width: 168px;
        padding: 18px;
      }

      .panel-main {
        left: 28px;
        right: 28px;
        bottom: 28px;
        padding: 24px;
      }

      .panel-main strong {
        display: block;
        font-family: "Space Grotesk", sans-serif;
        font-size: 1.35rem;
        line-height: 1.1;
        margin-bottom: 12px;
      }

      .panel-main p {
        color: var(--muted);
        font-size: 0.96rem;
        line-height: 1.7;
      }

      .panel-float {
        left: 28px;
        top: 34px;
        padding: 18px 18px 16px;
        max-width: 240px;
      }

      .panel-float span {
        display: block;
        color: #79d6ff;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin-bottom: 10px;
      }

      .panel-float strong {
        display: block;
        font-size: 1.1rem;
        line-height: 1.35;
      }

      .stats-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-top: 28px;
      }

      .stat-card,
      .feature-card,
      .testimonial-card,
      .discord-card,
      .cta-box,
      .about-panel,
      .apply-shell,
      .login-card,
      .application-form {
        border-radius: var(--radius);
        border: 1px solid var(--border);
        background: linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.03));
        box-shadow: var(--shadow);
      }

      .stat-card {
        padding: 22px;
      }

      .stat-card strong {
        display: block;
        font-family: "Space Grotesk", sans-serif;
        font-size: 2rem;
        letter-spacing: -0.04em;
      }

      .stat-card span {
        display: block;
        color: var(--muted);
        margin-top: 8px;
        font-size: 0.92rem;
      }

      .about-grid,
      .discord-grid,
      .apply-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
      }

      .about-panel {
        padding: 28px;
      }

      .about-panel h3,
      .login-card h3,
      .application-form h3 {
        font-family: "Space Grotesk", sans-serif;
        font-size: 1.35rem;
        margin-bottom: 12px;
      }

      .about-panel p,
      .login-card p,
      .application-form p {
        color: var(--muted);
        line-height: 1.8;
      }

      .about-list,
      .discord-points,
      .login-points {
        list-style: none;
        display: grid;
        gap: 14px;
      }

      .about-list {
        margin-top: 22px;
      }

      .about-list li,
      .login-points li {
        display: flex;
        gap: 12px;
        color: var(--muted-strong);
        line-height: 1.6;
      }

      .about-list li::before,
      .login-points li::before {
        content: "•";
        color: var(--primary);
        font-size: 1.2rem;
        line-height: 1;
        margin-top: 2px;
      }

      .feature-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
      }

      .feature-card {
        padding: 24px;
        min-height: 260px;
        transition: transform var(--transition), border-color var(--transition), background var(--transition);
      }

      .feature-card:hover {
        transform: translateY(-6px);
        border-color: rgba(0,174,255,0.26);
        background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(0,174,255,0.045));
      }

      .feature-icon {
        width: 50px;
        height: 50px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        background: rgba(0,174,255,0.1);
        border: 1px solid rgba(0,174,255,0.18);
        color: #9ee5ff;
        font-size: 1.1rem;
        margin-bottom: 18px;
      }

      .feature-card h3 {
        font-family: "Space Grotesk", sans-serif;
        font-size: 1.15rem;
        margin-bottom: 10px;
      }

      .feature-card p {
        color: var(--muted);
        line-height: 1.75;
        font-size: 0.95rem;
      }

      .testimonials-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .testimonial-card {
        padding: 26px;
      }

      .testimonial-card p {
        color: var(--muted-strong);
        line-height: 1.8;
        font-size: 0.98rem;
      }

      .testimonial-meta {
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,0.08);
      }

      .testimonial-meta strong {
        display: block;
        font-size: 0.95rem;
      }

      .testimonial-meta span {
        display: block;
        color: var(--muted);
        font-size: 0.85rem;
        margin-top: 4px;
      }

      .discord-card,
      .login-card,
      .application-form {
        position: relative;
        overflow: hidden;
        padding: 28px;
      }

      .discord-card.glow::before,
      .login-card::before {
        content: "";
        position: absolute;
        inset: 50% auto auto 50%;
        width: 360px;
        height: 360px;
        transform: translate(-50%, -50%);
        background: radial-gradient(circle, rgba(0,174,255,0.24), transparent 70%);
        filter: blur(18px);
        pointer-events: none;
      }

      .discord-card > *,
      .login-card > * {
        position: relative;
        z-index: 1;
      }

      .discord-live {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: #9fe6ff;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 18px;
      }

      .discord-live::before {
        content: "";
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--primary);
        box-shadow: 0 0 16px var(--primary-glow);
      }

      .discord-card h3 {
        font-family: "Space Grotesk", sans-serif;
        font-size: clamp(1.8rem, 4vw, 2.6rem);
        line-height: 1.02;
        margin-bottom: 14px;
      }

      .discord-card p {
        color: var(--muted);
        line-height: 1.8;
        max-width: 48ch;
      }

      .discord-count-box {
        margin-top: 24px;
        display: inline-flex;
        flex-direction: column;
        gap: 6px;
        padding: 18px 20px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.04);
      }

      .discord-count-box strong {
        font-family: "Space Grotesk", sans-serif;
        font-size: 2rem;
        letter-spacing: -0.04em;
      }

      .discord-count-box span {
        color: var(--muted);
        font-size: 0.88rem;
      }

      .discord-points li {
        padding: 18px 18px 18px 52px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: var(--muted-strong);
        line-height: 1.65;
        position: relative;
      }

      .discord-points li::before {
        content: "";
        position: absolute;
        left: 18px;
        top: 22px;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        border: 1px solid rgba(0,174,255,0.3);
        background: rgba(0,174,255,0.12);
        box-shadow: 0 0 18px rgba(0,174,255,0.12);
      }

      .apply-shell {
        padding: 14px;
      }

      .login-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        background: rgba(88, 101, 242, 0.12);
        border: 1px solid rgba(88, 101, 242, 0.24);
        color: #b9c2ff;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 14px;
      }

      .login-mock {
        margin-top: 22px;
        padding: 18px;
        border-radius: 20px;
        border: 1px dashed rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.02);
      }

      .login-mock strong {
        display: block;
        color: var(--text);
        margin-bottom: 8px;
      }

      .login-mock span {
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.7;
      }

      .application-form {
        opacity: 0.72;
      }

      .form-locked {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        margin-bottom: 22px;
      }

      .form-locked strong {
        display: block;
        margin-bottom: 4px;
      }

      .form-locked span {
        color: var(--muted);
        font-size: 0.9rem;
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .field {
        display: grid;
        gap: 8px;
        margin-bottom: 14px;
      }

      .field.full {
        grid-column: 1 / -1;
      }

      .field label {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--muted-strong);
      }

      .field input,
      .field select,
      .field textarea {
        width: 100%;
        border: 1px solid rgba(255,255,255,0.1);
        background: rgba(255,255,255,0.045);
        color: var(--text);
        border-radius: 14px;
        padding: 14px 14px;
        outline: none;
        font: inherit;
      }

      .field textarea {
        min-height: 120px;
        resize: vertical;
      }

      .field input::placeholder,
      .field textarea::placeholder {
        color: #7e95ad;
      }

      .form-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-top: 10px;
        padding-top: 18px;
        border-top: 1px solid rgba(255,255,255,0.08);
      }

      .form-note {
        color: var(--muted);
        font-size: 0.9rem;
        line-height: 1.7;
      }

      .submit-disabled {
        opacity: 0.6;
        cursor: not-allowed;
        pointer-events: none;
      }

      .cta-box {
        padding: 34px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
      }

      .cta-box h3 {
        font-family: "Space Grotesk", sans-serif;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        line-height: 1.02;
        margin-bottom: 10px;
      }

      .cta-box p {
        color: var(--muted);
        max-width: 58ch;
        line-height: 1.8;
      }

      footer {
        padding: 24px 0 60px;
      }

      .footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 24px;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--muted);
      }

      .footer-links {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
      }

      .footer-links a {
        color: var(--muted);
        font-size: 0.92rem;
      }

      @media (max-width: 1100px) {
        .hero-grid,
        .about-grid,
        .discord-grid,
        .apply-grid,
        .feature-grid,
        .testimonials-grid,
        .stats-row {
          grid-template-columns: repeat(2, 1fr);
        }

        .hero-panel {
          min-height: 460px;
        }
      }

      @media (max-width: 860px) {
        .nav-links {
          display: none;
        }

        .hero,
        .section {
          padding-top: 82px;
        }

        .hero-grid,
        .about-grid,
        .discord-grid,
        .apply-grid,
        .feature-grid,
        .testimonials-grid,
        .stats-row,
