---
export const prerender = false;

import MainLayout from "../layouts/MainLayout.astro";

// Read Discord session from cookie
const userCookie = Astro.cookies.get('dc_user');
let discordUser: { id: string; username: string; avatar: string | null } | null = null;
if (userCookie) {
  try {
    discordUser = JSON.parse(userCookie.value);
  } catch { /* invalid cookie */ }
}

const oauthError = Astro.url.searchParams.get('error') === 'oauth';
---

<MainLayout title="Capital Roleplay — Serious UK FiveM Roleplay">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="hero-tag-box">
          <span>Whitelisted serious roleplay based in the United Kingdom</span>
        </div>

        <h1>A more <span>premium</span> FiveM roleplay experience.</h1>
        <p>
          Capital Roleplay is a whitelisted FiveM server built for players who want a
          cleaner, more immersive, and more deliberate roleplay environment. From vehicles
          and clothing to weapons and scripts, the experience is shaped around custom-built quality.
        </p>

        <div class="hero-actions">
          <a class="button" href="#apply">Apply for Whitelist</a>
          <a class="button ghost" href="#about">About the Server</a>
        </div>

        <div class="hero-meta">
          <div class="meta-chip">Custom Cars</div>
          <div class="meta-chip">Custom Clothing</div>
          <div class="meta-chip">Custom Weapons</div>
          <div class="meta-chip">Custom Scripts</div>
        </div>
      </div>

      <div class="hero-panel">
        <div class="panel-card panel-float">
          <span>Capital Identity</span>
          <strong>Serious UK roleplay with custom-built depth and a whitelist standard.</strong>
        </div>

        <div class="panel-card panel-logo">
          <div class="hero-logo-circle">
            <img src="/logo.png" alt="Capital Roleplay emblem" />
          </div>
        </div>

        <div class="panel-card panel-main">
          <strong>Built to feel premium from the first minute.</strong>
          <p>
            Capital Roleplay is designed to avoid the recycled feel of generic public servers.
            The world, systems, and presentation are aligned around immersion, consistency, and
            long-term community quality.
          </p>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="stats-row">
        <div class="stat-card">
          <strong>WL</strong>
          <span>Whitelisted Access</span>
        </div>
        <div class="stat-card">
          <strong>24/7</strong>
          <span>Server Availability</span>
        </div>
        <div class="stat-card">
          <strong>UK</strong>
          <span>Roleplay Identity</span>
        </div>
        <div class="stat-card">
          <strong>100%</strong>
          <span>Custom Server Direction</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <div class="showcase-banner">
        <video
          src="https://pub-80ebeb36fdbb49b4966de28f8ce1b7a3.r2.dev/website/background.mp4"
          autoplay
          loop
          muted
          playsinline
          preload="none"
        ></video>

        <div class="showcase-inner">
          <div class="showcase-tag">High quality // Ready to play</div>
          <h2>Built for serious roleplay</h2>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">About us</div>
        <h2>Capital Roleplay is built around quality-first serious roleplay.</h2>
        <p>
          This is not a fast-launch, copy-paste server. Capital Roleplay is positioned as a more
          refined environment for players who care about immersion, proper faction standards,
          and long-term character development.
        </p>
      </div>

      <div class="about-grid">
        <div class="about-panel">
          <h3>What separates the server</h3>
          <p>
            Nearly every major part of the player experience is custom-built. That means the world
            feels more coherent, the identity feels stronger, and the gameplay avoids the same public
            content seen across generic FiveM servers.
          </p>
          <ul class="about-list">
            <li>Custom vehicles, clothing, weapons, interfaces, and scripts</li>
            <li>Whitelist access to maintain a better player standard</li>
            <li>Higher focus on realism, storytelling, and consistency</li>
          </ul>
        </div>

        <div class="about-panel">
          <h3>What players can expect</h3>
          <p>
            Capital Roleplay is designed for players who want to invest in proper characters,
            serious factions, player-run storylines, and a city that feels intentionally crafted
            rather than randomly assembled.
          </p>
          <ul class="about-list">
            <li>Stronger immersion and cleaner community structure</li>
            <li>Long-term potential for legal and illegal faction roleplay</li>
            <li>Premium presentation across the full server experience</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Core pillars</div>
        <h2>Custom content is the baseline, not the headline gimmick.</h2>
        <p>
          The real value comes from how the visuals, systems, and roleplay standards support each other.
          The result is a server that feels more premium and more controlled from top to bottom.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
          <h3>Custom Asset Direction</h3>
          <p>Vehicles, clothing, weapons, and visual identity built to give the server its own recognisable feel.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-ranking-star"></i></div>
          <h3>Whitelist Standard</h3>
          <p>Applications help maintain a better player base and protect the overall quality of roleplay.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-user-shield"></i></div>
          <h3>Faction Potential</h3>
          <p>Structured support for organised legal and illegal roleplay, built on serious community standards.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-people-line"></i></div>
          <h3>Premium Presentation</h3>
          <p>A polished front-end, consistent design language, and cleaner onboarding for new players.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="discord">
    <div class="container">
      <div class="dc-outer">

        <div class="dc-top">
          <div class="dc-eyebrow">
            <span class="dc-dot"></span>
            <span>Our Community</span>
          </div>
          <h2 class="dc-heading">
            Built for those who<br />
            <span class="dc-heading-accent">demand the city.</span>
          </h2>
          <p class="dc-sub">Join hundreds of members in our Discord — applications, announcements, and community onboarding all start here.</p>
        </div>

        <div class="dc-cards">

          <div class="dc-stats-card">
            <div class="dc-live-row">
              <span class="dc-live-dot"></span>
              <span class="dc-live-text">Live Stats</span>
            </div>
            <div class="dc-numbers-row">
              <div class="dc-num-block">
                <strong id="discordMemberCount" data-fallback="—">—</strong>
                <span>Members</span>
              </div>
              <div class="dc-num-sep"></div>
              <div class="dc-num-block">
                <strong id="discordOnlineCount" data-fallback="—">—</strong>
                <span>Online</span>
              </div>
            </div>
            <p class="dc-source">Data provided by <a href="https://discord.com" target="_blank" rel="noreferrer">Discord</a></p>
          </div>

          <div class="dc-join-card">
            <div class="dc-online-pill">
              <span class="dc-online-dot"></span>
              <span>Online</span>
            </div>
            <h3 class="dc-join-title">Capital Roleplay</h3>
            <p class="dc-join-body">Discord is where the community lives. Join to apply for whitelist, follow updates, and connect before you enter the city.</p>
            <a class="dc-join-btn" href="https://discord.gg/drpNDbTgBM" target="_blank" rel="noreferrer">
              Join Capital Roleplay &rarr;
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <section class="section" id="apply">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Whitelist application</div>
        <h2>Apply to join Capital Roleplay.</h2>
        <p>
          Sign in with Discord to verify your identity, then fill in the form below.
          Submitted applications are reviewed by staff directly in our Discord server.
        </p>
      </div>

      {oauthError && (
        <div class="apply-error">
          Discord login failed — please try again.
        </div>
      )}

      <div class="apply-shell">
        <div class="apply-grid">

          {/* LEFT: Auth card */}
          {discordUser ? (
            <div class="login-card login-card--authed">
              <div class="login-badge login-badge--ok">Step 1 · Authenticated</div>
              <h3>Signed in as Discord</h3>

              <div class="dc-user-row">
                <img
                  class="dc-user-avatar"
                  src={discordUser.avatar
                    ? `https://cdn.discordapp.com/avatars/${discordUser.id}/${discordUser.avatar}.png?size=64`
                    : `https://cdn.discordapp.com/embed/avatars/0.png`}
                  alt="Discord avatar"
                />
                <div>
                  <strong class="dc-user-name">{discordUser.username}</strong>
                  <span class="dc-user-id">ID {discordUser.id}</span>
                </div>
              </div>

              <ul class="login-points" style="margin-top: 22px;">
                <li>Identity verified via Discord OAuth</li>
                <li>Your Discord username is pre-filled in the form</li>
                <li>Application is submitted directly to our staff channel</li>
              </ul>

              <div style="margin-top: 24px;">
                <a class="button ghost small" href="/api/auth/logout">Sign out</a>
              </div>
            </div>
          ) : (
            <div class="login-card">
              <div class="login-badge">Step 1 · Discord login required</div>
              <h3>Authenticate with Discord first</h3>
              <p>
                You must sign in with Discord before submitting an application.
                This verifies your identity and links your application to your account.
              </p>

              <div style="margin-top: 22px;">
                <a class="button discord" href="/api/auth/discord">Continue with Discord</a>
              </div>

              <ul class="login-points" style="margin-top: 22px;">
                <li>Discord account required before applying</li>
                <li>Your username will be pre-filled automatically</li>
                <li>Applications are forwarded to our staff review channel</li>
              </ul>
            </div>
          )}

          {/* RIGHT: Form */}
          <div class={`application-form${discordUser ? '' : ' application-form--locked'}`}>
            <h3>Whitelist form</h3>
            {discordUser ? (
              <p>Form is unlocked. Fill in your details and submit below.</p>
            ) : (
              <p>Sign in with Discord on the left to unlock and submit this application.</p>
            )}

            {!discordUser && (
              <div class="form-locked">
                <div>
                  <strong>Form locked</strong>
                  <span>Sign in with Discord to unlock.</span>
                </div>
              </div>
            )}

            <div id="apply-success" class="apply-success" style="display:none">
              <strong>Application submitted!</strong>
              <span>Our staff team will review it shortly. Keep an eye on your Discord DMs.</span>
            </div>

            <div id="apply-error-msg" class="apply-error-inline" style="display:none"></div>

            <form id="apply-form">
              <div class="form-grid">
                <div class="field">
                  <label for="fullname">Full Name <span class="field-required">*</span></label>
                  <input id="fullname" name="fullname" type="text" placeholder="John Smith" disabled={!discordUser} />
                </div>

                <div class="field">
                  <label for="discord-username">Discord Username</label>
                  <input
                    id="discord-username"
                    name="discord-username"
                    type="text"
                    value={discordUser?.username ?? ''}
                    readonly
                    disabled={!discordUser}
                  />
                </div>

                <div class="field">
                  <label for="age">Age <span class="field-required">*</span></label>
                  <select id="age" name="age" disabled={!discordUser}>
                    <option value="">Select your age range</option>
                    <option value="16–17">16–17</option>
                    <option value="18–20">18–20</option>
                    <option value="21–25">21–25</option>
                    <option value="26+">26+</option>
                  </select>
                </div>

                <div class="field">
                  <label for="experience">Roleplay Experience <span class="field-required">*</span></label>
                  <select id="experience" name="experience" disabled={!discordUser}>
                    <option value="">Select experience level</option>
                    <option value="Beginner">Beginner</option>
                    <option value="Intermediate">Intermediate</option>
                    <option value="Experienced">Experienced</option>
                    <option value="Veteran">Veteran</option>
                  </select>
                </div>

                <div class="field full">
                  <label for="character">Character Concept <span class="field-optional">(Optional)</span></label>
                  <textarea id="character" name="character" placeholder="Describe the type of character you plan to play and how they would fit into the city." disabled={!discordUser}></textarea>
                </div>

                <div class="field full">
                  <label for="whyjoin">Why do you want to join Capital Roleplay? <span class="field-required">*</span></label>
                  <textarea id="whyjoin" name="whyjoin" placeholder="Explain what attracts you to the server and what kind of roleplay you are looking for. Minimum 100 words required." disabled={!discordUser}></textarea>
                  <div class="field-wordcount">
                    <span id="whyjoin-count">0</span> / 100 words minimum
                  </div>
                </div>
              </div>

              <div class="form-footer">
                <div class="form-note">
                  {discordUser
                    ? 'Your application will be sent directly to our staff review channel.'
                    : 'Sign in with Discord to enable submission.'}
                </div>
                <button
                  type="submit"
                  id="submit-btn"
                  class={`button${discordUser ? '' : ' submit-disabled'}`}
                  disabled={!discordUser}
                >Submit Application</button>
              </div>
            </form>
          </div>

        </div>
      </div>
    </div>
  </section>

  <section class="section" id="testimonials">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Launch structure</div>
        <h2>Placeholder quotes until real community feedback is added.</h2>
        <p>
          These are layout placeholders only. Replace them later with real testimonials from your
          community, staff team, or early testers.
        </p>
      </div>

      <div class="testimonials-grid">
        <article class="testimonial-card">
          <p>“The server immediately feels more deliberate than the usual public FiveM setup. The quality direction is obvious.”</p>
          <div class="testimonial-meta">
            <strong>Lewis H.</strong>
            <span>Community Member</span>
          </div>
        </article>

        <article class="testimonial-card">
          <p>“The whitelist angle makes sense because the server is clearly aiming for stronger standards and more serious character roleplay.”</p>
          <div class="testimonial-meta">
            <strong>Aiden R.</strong>
            <span>Faction Player</span>
          </div>
        </article>

        <article class="testimonial-card">
          <p>“It looks like a server that wants long-term identity, not short-term hype. That already separates it.”</p>
          <div class="testimonial-meta">
            <strong>Mason K.</strong>
            <span>Applicant</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-box">
        <div>
          <h3>Whitelist access. Premium standard. Serious roleplay.</h3>
          <p>
            Capital Roleplay is being positioned as a cleaner and more refined FiveM experience for
            players who want custom content, stronger immersion, and a server identity with actual direction.
          </p>
        </div>

        <a class="button" href="#apply">Start Application</a>
      </div>
    </div>
  </section>

  <script>
    // Word counter
    const whyjoinEl = document.getElementById("whyjoin") as HTMLTextAreaElement | null;
    const whyjoinCount = document.getElementById("whyjoin-count");

    function countWords(str: string) {
      return str.trim().split(/\s+/).filter(w => w.length > 0).length;
    }

    if (whyjoinEl && whyjoinCount) {
      whyjoinEl.addEventListener("input", () => {
        const words = countWords(whyjoinEl.value);
        whyjoinCount.textContent = String(words);
        const valid = words >= 100;
        whyjoinCount.parentElement!.classList.toggle("valid", valid);
        whyjoinCount.parentElement!.classList.toggle("invalid", !valid && words > 0);
      });
    }

    // Application form submit
    const form = document.getElementById("apply-form") as HTMLFormElement | null;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement | null;
    const successEl = document.getElementById("apply-success");
    const errorEl = document.getElementById("apply-error-msg");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!submitBtn || submitBtn.disabled) return;

      const fullname = (document.getElementById("fullname") as HTMLInputElement).value.trim();
      const age = (document.getElementById("age") as HTMLSelectElement).value;
      const experience = (document.getElementById("experience") as HTMLSelectElement).value;
      const character = (document.getElementById("character") as HTMLTextAreaElement).value.trim();
      const whyjoin = (document.getElementById("whyjoin") as HTMLTextAreaElement).value.trim();

      const words = countWords(whyjoin);
      if (words < 100) {
        if (errorEl) {
          errorEl.textContent = `"Why do you want to join" needs at least 100 words (you have ${words}).`;
          errorEl.style.display = "block";
        }
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Submitting…";
      if (errorEl) errorEl.style.display = "none";

      try {
        const res = await fetch("/api/apply", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ fullname, age, experience, character, whyjoin }),
        });

        const data = await res.json();

        if (res.ok) {
          form.style.display = "none";
          if (successEl) successEl.style.display = "block";
        } else {
          if (errorEl) {
            errorEl.textContent = data.error ?? "Submission failed — please try again.";
            errorEl.style.display = "block";
          }
          submitBtn.disabled = false;
          submitBtn.textContent = "Submit Application";
        }
      } catch {
        if (errorEl) {
          errorEl.textContent = "Network error — please check your connection and try again.";
          errorEl.style.display = "block";
        }
        submitBtn.disabled = false;
        submitBtn.textContent = "Submit Application";
      }
    });
  </script>

  <script>
    const WORKER_URL = "https://royal-truth-48c4-capital-roleplay-discordcounter.skagebakk.workers.dev";

    const memberEl = document.getElementById("discordMemberCount");
    const onlineEl = document.getElementById("discordOnlineCount");

    let lastMembers = 0;
    let lastOnline = 0;
    let retryTimeout = null;

    function fmt(n) {
      return new Intl.NumberFormat("en-GB").format(n);
    }

    function render() {
      if (memberEl) memberEl.textContent = lastMembers > 0 ? fmt(lastMembers) : "—";
      if (onlineEl) onlineEl.textContent = lastOnline > 0 ? fmt(lastOnline) : "—";
    }

    async function loadDiscordStats(retryCount = 0) {
      try {
        const res = await fetch(WORKER_URL);
        if (!res.ok) throw new Error("status " + res.status);
        const data = await res.json();

        const gotMembers = typeof data.members === "number" && data.members > 0;
        const gotOnline  = typeof data.online  === "number" && data.online  > 0;

        if (gotMembers) lastMembers = data.members;
        if (gotOnline)  lastOnline  = data.online;

        render();

        // If Discord returned 0s (cold-start glitch), retry quickly up to 5 times
        if (!gotMembers && !gotOnline && retryCount < 5) {
          clearTimeout(retryTimeout);
          retryTimeout = setTimeout(() => loadDiscordStats(retryCount + 1), 2_000);
          return;
        }
      } catch {
        // Network error — keep whatever is displayed, retry shortly if still on first load
        if (retryCount < 3) {
          clearTimeout(retryTimeout);
          retryTimeout = setTimeout(() => loadDiscordStats(retryCount + 1), 3_000);
          return;
        }
      }
    }

    loadDiscordStats();
    setInterval(() => loadDiscordStats(), 60_000);
  </script>
</MainLayout>