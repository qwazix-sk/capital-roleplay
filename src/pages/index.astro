---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Capital Roleplay — Serious UK FiveM Roleplay">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="hero-tag-box">
          <span>Whitelisted serious roleplay based in the United Kingdom</span>
        </div>

        <h1>A more <span>premium</span> FiveM roleplay experience.</h1>
        <p>
          Capital Roleplay is a whitelisted FiveM server built for players who want a
          cleaner, more immersive, and more deliberate roleplay environment. From vehicles
          and clothing to weapons and scripts, the experience is shaped around custom-built quality.
        </p>

        <div class="hero-actions">
          <a class="button" href="#apply">Apply for Whitelist</a>
          <div class="meta-chip meta-chip--age">18+ Only</div>
        </div>

        <div class="hero-meta">
          <div class="meta-chip">Custom Cars</div>
          <div class="meta-chip">Custom Clothing</div>
          <div class="meta-chip">Custom Weapons</div>
          <div class="meta-chip">Custom Scripts</div>
        </div>

      </div>

      <div class="hero-panel">
        <div class="panel-card panel-float">
          <span>Capital Identity</span>
          <strong>Serious UK roleplay with custom-built depth and a whitelist standard.</strong>
        </div>

        <div class="panel-card panel-logo">
          <div class="hero-logo-circle">
            <img src="/logo.png" alt="Capital Roleplay emblem" />
          </div>
        </div>

        <div class="panel-card panel-main" id="fivemPanel">
          <div class="pm-header">
            <span class="fc-status-tag fc-status-tag--live pm-status-tag" id="fivemStatusPill">
              <span class="dc-online-dot" aria-hidden="true"></span>
              <span id="fivemStatusLabel">Live</span>
            </span>
            <span class="pm-server-name">Capital Roleplay</span>
          </div>

          <div class="pm-body">
            <span class="pm-num" id="fivemPlayerCount">—</span>
            <span class="pm-slash">/</span>
            <span class="pm-of-max" id="fivemMaxPlayers">—</span>
            <span class="pm-in-game">Players online</span>
          </div>

          <div class="pm-offline-block" aria-live="polite">
            <strong>Server Offline</strong>
            <span>Checking again in 30s</span>
          </div>

          <a class="pm-connect" id="fivemConnectBtn" href="#" target="_blank" rel="noreferrer">
            Connect to server <i class="fa-solid fa-arrow-right"></i>
          </a>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="stats-row">
        <div class="stat-card">
          <strong>WL Only</strong>
          <span>Application-only entry — no open slots</span>
        </div>
        <div class="stat-card">
          <strong>24/7</strong>
          <span>Live around the clock, no downtime windows</span>
        </div>
        <div class="stat-card">
          <strong>UK Built</strong>
          <span>British identity, culture, and city layout</span>
        </div>
        <div class="stat-card">
          <strong>Custom Assets</strong>
          <span>Every asset is custom — nothing off the shelf</span>
        </div>
      </div>

    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <div class="showcase-banner">
        <video
          src="https://pub-80ebeb36fdbb49b4966de28f8ce1b7a3.r2.dev/website/Caprptest.webm"
          autoplay
          loop
          muted
          playsinline
          preload="none"
        ></video>

        <div class="showcase-inner">
          <div class="showcase-tag">High quality // Ready to play</div>
          <h2>Built for serious roleplay</h2>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tight" id="about">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">About us</div>
        <h2>Capital Roleplay is built around quality-first serious roleplay.</h2>
        <p>
          This is not a fast-launch, copy-paste server. Capital Roleplay is positioned as a more
          refined environment for players who care about immersion, proper faction standards,
          and long-term character development.
        </p>
      </div>

      <div class="about-grid">
        <div class="about-panel">
          <h3>What separates the server</h3>
          <p>
            Nearly every major part of the player experience is custom-built. That means the world
            feels more coherent, the identity feels stronger, and the gameplay avoids the same public
            content seen across generic FiveM servers.
          </p>
          <ul class="about-list">
            <li>Custom vehicles, clothing, weapons, interfaces, and scripts</li>
            <li>Whitelist access to maintain a better player standard</li>
            <li>Higher focus on realism, storytelling, and consistency</li>
          </ul>
        </div>

        <div class="about-panel">
          <h3>What players can expect</h3>
          <p>
            Capital Roleplay is designed for players who want to invest in proper characters,
            serious factions, player-run storylines, and a city that feels intentionally crafted
            rather than randomly assembled.
          </p>
          <ul class="about-list">
            <li>Stronger immersion and cleaner community structure</li>
            <li>Long-term potential for legal and illegal faction roleplay</li>
            <li>Premium presentation across the full server experience</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="discord">
    <div class="container">
      <div class="dc-outer">

        <div class="dc-top">
          <div class="dc-eyebrow">
            <span class="dc-dot"></span>
            <span>Our Community</span>
          </div>
          <h2 class="dc-heading">
            Built for those who<br />
            <span class="dc-heading-accent">demand the city.</span>
          </h2>
          <p class="dc-sub">Join hundreds of members in our Discord — applications, announcements, and community onboarding all start here.</p>
        </div>

        <div class="dc-cards">

          <div class="dc-stats-card">
            <span class="fc-status-tag fc-status-tag--featured dc-live-tag">
              <i class="fa-solid fa-wave-square" aria-hidden="true"></i>
              <span>Live Stats</span>
            </span>
            <div class="dc-numbers-row">
              <div class="dc-num-block">
                <strong id="discordMemberCount" data-fallback="—">—</strong>
                <span>Members</span>
              </div>
              <div class="dc-num-sep"></div>
              <div class="dc-num-block">
                <strong id="discordOnlineCount" data-fallback="—">—</strong>
                <span>Online</span>
              </div>
            </div>
            <p class="dc-source">Data provided by <a href="https://discord.com" target="_blank" rel="noreferrer">Discord</a></p>
          </div>

          <div class="dc-join-card">
            <span class="fc-status-tag fc-status-tag--live dc-online-tag">
              <span class="dc-online-dot" aria-hidden="true"></span>
              <span>Online</span>
            </span>
            <h3 class="dc-join-title">Capital Roleplay</h3>
            <p class="dc-join-body">Discord is where the community lives. Join to apply for whitelist, follow updates, and connect before you enter the city.</p>
            <a class="dc-join-btn" href="https://discord.gg/drpNDbTgBM" target="_blank" rel="noreferrer">
              Join Capital Roleplay &rarr;
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <section class="section" id="apply">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Whitelist application</div>
        <h2>Apply to join Capital Roleplay.</h2>
        <p>
          Sign in with Discord to verify your identity, then fill in the form below.
          Submitted applications are reviewed by staff directly in our Discord server.
        </p>
      </div>

      <div id="oauth-error-msg" class="apply-error" style="display:none">
        Discord login failed — please try again.
      </div>

      <div class="apply-shell">
        <div class="apply-grid">

          <!-- LEFT: Auth card (default: unauthenticated — JS swaps to authenticated) -->
          <div id="auth-card" class="login-card">
            <div class="login-badge">Step 1 · Discord login required</div>
            <h3>Authenticate with Discord first</h3>
            <p>
              You must sign in with Discord before submitting an application.
              This verifies your identity and links your application to your account.
            </p>

            <div style="margin-top: 22px;">
              <a class="button discord" href="/api/auth/discord">Continue with Discord</a>
            </div>

            <ul class="login-points" style="margin-top: 22px;">
              <li>Discord account required before applying</li>
              <li>Verifies your identity and links it to your application</li>
              <li>Applications are forwarded to our staff review channel</li>
            </ul>
          </div>

          <!-- RIGHT: Form (default: locked — JS unlocks when authenticated) -->
          <div id="apply-form-wrapper" class="application-form application-form--locked">
            <h3>Whitelist form</h3>
            <p id="form-status-text">Sign in with Discord on the left to unlock and submit this application.</p>

            <div id="form-locked-overlay" class="form-locked">
              <div>
                <strong>Form locked</strong>
                <span>Sign in with Discord to unlock.</span>
              </div>
            </div>

            <div id="apply-success" class="apply-success" style="display:none">
              <strong>Application submitted!</strong>
              <span>Our staff team will review it shortly. Keep an eye on your Discord DMs.</span>
            </div>

            <div id="apply-error-msg" class="apply-error-inline" style="display:none"></div>

            <form id="apply-form">
              <div class="form-grid">
                <div class="field">
                  <label for="fullname">Intended Character Name <span class="field-required">*</span></label>
                  <input id="fullname" name="fullname" type="text" placeholder="e.g. James Calloway" disabled />
                </div>

                <div class="field">
                  <label for="dob">Date of Birth (IRL) <span class="field-required">*</span></label>
                  <input id="dob" name="dob" type="text" inputmode="numeric" autocomplete="bday" placeholder="mm/dd/yyyy" maxlength="10" disabled />
                </div>

                <div class="field full">
                  <label for="experience">Roleplay Experience <span class="field-required">*</span></label>
                  <textarea id="experience" name="experience" placeholder="Describe your previous roleplay experience, including any FiveM RP servers you have played on previously." disabled></textarea>
                </div>

                <div class="field full">
                  <label for="character">Character Concept <span class="field-optional">(Optional)</span></label>
                  <textarea id="character" name="character" placeholder="Describe the type of character you plan to play and how they would fit into the city." disabled></textarea>
                </div>

                <div class="field full">
                  <label for="whyjoin">Why do you want to join Capital Roleplay? <span class="field-required">*</span></label>
                  <textarea id="whyjoin" name="whyjoin" placeholder="Explain what attracts you to the server and what kind of roleplay you are looking for. Minimum 100 words required." disabled></textarea>
                  <div class="field-wordcount" id="charcount-wrap">
                    <span id="whyjoin-count">0</span> / 100 words minimum
                    <span class="charcount-sep">·</span>
                    <span id="charcount-used">0</span> / 6,000 characters
                  </div>
                </div>
              </div>

              <div class="form-footer">
                <div id="form-note-text" class="form-note">Sign in with Discord to enable submission.</div>
                <button
                  type="submit"
                  id="submit-btn"
                  class="button submit-disabled"
                  disabled
                >Submit Application</button>
              </div>
            </form>
          </div>

        </div>
      </div>
    </div>
  </section>

  <section class="section" id="features">
    <div class="container">
      <div class="section-header">
        <div class="eyebrow">Core pillars</div>
        <h2>Custom content is the baseline, not the headline gimmick.</h2>
        <p>
          The real value comes from how the visuals, systems, and roleplay standards support each other.
          The result is a server that feels more premium and more controlled from top to bottom.
        </p>
      </div>

      <div class="feature-grid">
        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
          <h3>Custom Asset Direction</h3>
          <p>Vehicles, clothing, weapons, and visual identity built to give the server its own recognisable feel.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-ranking-star"></i></div>
          <h3>Whitelist Standard</h3>
          <p>Applications help maintain a better player base and protect the overall quality of roleplay.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-user-shield"></i></div>
          <h3>Faction Potential</h3>
          <p>Structured support for organised legal and illegal roleplay, built on serious community standards.</p>
        </article>

        <article class="feature-card">
          <div class="feature-icon"><i class="fa-solid fa-people-line"></i></div>
          <h3>Premium Presentation</h3>
          <p>A polished front-end, consistent design language, and cleaner onboarding for new players.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <div class="cta-box">
        <div>
          <h3>Whitelist access. Premium standard. Serious roleplay.</h3>
          <p>
            Capital Roleplay is being positioned as a cleaner and more refined FiveM experience for
            players who want custom content, stronger immersion, and a server identity with actual direction.
          </p>
        </div>

        <a class="button" href="#apply">Start Application</a>
      </div>
    </div>
  </section>

  <script>
    // ── Client-side auth detection ──────────────────────────────────────────
    (function () {
      function esc(str: string) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      // Parse dc_user cookie (client-readable, not httpOnly)
      let discordUser: { id: string; username: string; avatar: string | null } | null = null;
      const match = document.cookie.split('; ').find(r => r.startsWith('dc_user='));
      if (match) {
        try {
          discordUser = JSON.parse(decodeURIComponent(match.split('=').slice(1).join('=')));
        } catch { /* invalid cookie */ }
      }

      // Show OAuth error if present in URL
      const urlParams = new URLSearchParams(window.location.search);
      const hashParams = new URLSearchParams(window.location.hash.split('?')[1] ?? '');
      if (urlParams.get('error') === 'oauth' || hashParams.get('error') === 'oauth') {
        const errEl = document.getElementById('oauth-error-msg');
        if (errEl) errEl.style.display = 'block';
      }

      if (!discordUser) return;

      // Swap auth card to authenticated state
      const authCard = document.getElementById('auth-card');
      if (authCard) {
        const avatarUrl = discordUser.avatar
          ? `https://cdn.discordapp.com/avatars/${esc(discordUser.id)}/${esc(discordUser.avatar)}.png?size=64`
          : `https://cdn.discordapp.com/embed/avatars/0.png`;
        authCard.className = 'login-card login-card--authed';
        authCard.innerHTML = `
          <div class="login-badge login-badge--ok">Step 1 &middot; Authenticated</div>
          <h3>Signed in with Discord</h3>
          <div class="dc-user-row">
            <img class="dc-user-avatar" src="${avatarUrl}" alt="Discord avatar" />
            <div>
              <strong class="dc-user-name">${esc(discordUser.username)}</strong>
              <span class="dc-user-id">ID ${esc(discordUser.id)}</span>
            </div>
          </div>
          <ul class="login-points" style="margin-top:22px">
            <li>Identity verified via Discord OAuth</li>
            <li>Application submitted directly to our staff channel</li>
            <li>You will receive a DM with the decision</li>
          </ul>
          <div style="margin-top:24px">
            <a class="button ghost small logout" href="/api/auth/logout">Sign out</a>
          </div>
        `;
      }

      // Unlock form
      const wrapper = document.getElementById('apply-form-wrapper');
      if (wrapper) wrapper.classList.remove('application-form--locked');

      const overlay = document.getElementById('form-locked-overlay');
      if (overlay) overlay.remove();

      document.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
        '#apply-form input, #apply-form select, #apply-form textarea'
      ).forEach(el => el.removeAttribute('disabled'));

      const statusText = document.getElementById('form-status-text');
      if (statusText) statusText.textContent = 'Form is unlocked. Fill in your details and submit below.';

      const noteText = document.getElementById('form-note-text');
      if (noteText) noteText.textContent = 'Your application will be sent directly to our staff review channel.';

      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
      if (submitBtn) {
        submitBtn.removeAttribute('disabled');
        submitBtn.className = 'button';
      }
    })();

    // ── DOB formatter (mm/dd/yyyy, input-driven, IME-safe) ──────────────────
    // Value holds only real digits + slash separators. No underscore padding,
    // no setSelectionRange, no keydown preventDefault — those break Samsung
    // Keyboard / GBoard composition on Android.
    const dobEl = document.getElementById('dob') as HTMLInputElement | null;
    if (dobEl) {
      let dobPrev = '';

      function formatDob(digits: string): string {
        digits = digits.slice(0, 8);
        let out = digits.slice(0, 2);
        if (digits.length >= 2) out += '/' + digits.slice(2, 4);
        if (digits.length >= 4) out += '/' + digits.slice(4, 8);
        return out;
      }

      dobEl.addEventListener('input', () => {
        let digits = dobEl.value.replace(/\D/g, '').slice(0, 8);
        // If the user deleted a slash (length shrank but digit count didn't),
        // also drop the preceding digit so backspace feels natural.
        const prevDigits = dobPrev.replace(/\D/g, '');
        if (
          dobEl.value.length < dobPrev.length &&
          digits.length === prevDigits.length &&
          digits.length > 0
        ) {
          digits = digits.slice(0, -1);
        }
        const formatted = formatDob(digits);
        if (formatted !== dobEl.value) dobEl.value = formatted;
        dobPrev = formatted;
      });
    }

    // ── Word counter + shared char counter ──────────────────────────────────
    const whyjoinEl    = document.getElementById('whyjoin')    as HTMLTextAreaElement | null;
    const experienceEl = document.getElementById('experience') as HTMLTextAreaElement | null;
    const characterEl  = document.getElementById('character')  as HTMLTextAreaElement | null;
    const whyjoinCount = document.getElementById('whyjoin-count');
    const charcountUsed = document.getElementById('charcount-used');
    const CHAR_LIMIT = 6000;

    function countWords(str: string) {
      return str.trim().split(/\s+/).filter(w => w.length > 0).length;
    }

    function updateCharCount() {
      const total = (experienceEl?.value.length ?? 0)
                  + (characterEl?.value.length  ?? 0)
                  + (whyjoinEl?.value.length    ?? 0);
      if (charcountUsed) {
        charcountUsed.textContent = String(total);
        const wrap = document.getElementById('charcount-wrap');
        wrap?.classList.toggle('over', total > CHAR_LIMIT);
      }
    }

    if (whyjoinEl && whyjoinCount) {
      whyjoinEl.addEventListener('input', () => {
        const words = countWords(whyjoinEl.value);
        whyjoinCount.textContent = String(words);
        const valid = words >= 100;
        whyjoinCount.parentElement!.classList.toggle('valid', valid);
        whyjoinCount.parentElement!.classList.toggle('invalid', !valid && words > 0);
        updateCharCount();
      });
    }
    experienceEl?.addEventListener('input', updateCharCount);
    characterEl?.addEventListener('input', updateCharCount);

    // ── Draft persistence ────────────────────────────────────────────────────
    const WL_DRAFT_KEY = 'wl_form_draft';

    function saveDraft() {
      localStorage.setItem(WL_DRAFT_KEY, JSON.stringify({
        fullname:   (document.getElementById('fullname')   as HTMLInputElement)?.value  ?? '',
        dob:        (document.getElementById('dob')        as HTMLInputElement)?.value  ?? '',
        experience: experienceEl?.value ?? '',
        character:  characterEl?.value  ?? '',
        whyjoin:    whyjoinEl?.value    ?? '',
      }));
    }

    document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
      '#apply-form input, #apply-form textarea'
    ).forEach(el => el.addEventListener('input', saveDraft));

    (function restoreDraft() {
      let draft: Record<string, string> | null = null;
      try { draft = JSON.parse(localStorage.getItem(WL_DRAFT_KEY) ?? 'null'); } catch { return; }
      if (!draft) return;
      const fullnameInput = document.getElementById('fullname') as HTMLInputElement | null;
      const dobInput      = document.getElementById('dob')      as HTMLInputElement | null;
      if (fullnameInput && draft.fullname) fullnameInput.value = draft.fullname;
      if (dobInput && draft.dob) { dobInput.value = draft.dob; dobInput.dispatchEvent(new Event('input')); }
      if (experienceEl && draft.experience) { experienceEl.value = draft.experience; experienceEl.dispatchEvent(new Event('input')); }
      if (characterEl  && draft.character)  { characterEl.value  = draft.character;  characterEl.dispatchEvent(new Event('input'));  }
      if (whyjoinEl    && draft.whyjoin)    { whyjoinEl.value    = draft.whyjoin;    whyjoinEl.dispatchEvent(new Event('input'));    }
    })();

    // ── Form submit ─────────────────────────────────────────────────────────
    const form = document.getElementById('apply-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const successEl = document.getElementById('apply-success');
    const errorEl = document.getElementById('apply-error-msg');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!submitBtn || submitBtn.disabled) return;

      const fullname = (document.getElementById('fullname') as HTMLInputElement).value.trim();
      const dob = (document.getElementById('dob') as HTMLInputElement).value.trim();
      const experience = (document.getElementById('experience') as HTMLTextAreaElement).value.trim();
      const character = (document.getElementById('character') as HTMLTextAreaElement).value.trim();
      const whyjoin = (document.getElementById('whyjoin') as HTMLTextAreaElement).value.trim();

      if (!experience) {
        if (errorEl) {
          errorEl.textContent = 'Please describe your roleplay experience before submitting.';
          errorEl.style.display = 'block';
        }
        return;
      }

      const words = countWords(whyjoin);
      if (words < 100) {
        if (errorEl) {
          errorEl.textContent = `"Why do you want to join" needs at least 100 words (you have ${words}).`;
          errorEl.style.display = 'block';
        }
        return;
      }

      const totalChars = experience.length + character.length + whyjoin.length;
      if (totalChars > CHAR_LIMIT) {
        if (errorEl) {
          errorEl.textContent = `Your answers are too long (${totalChars} / ${CHAR_LIMIT} characters). Please shorten your responses.`;
          errorEl.style.display = 'block';
        }
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
      if (errorEl) errorEl.style.display = 'none';

      try {
        const res = await fetch('/api/apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ fullname, dob, experience, character, whyjoin }),
        });

        const data = await res.json();

        if (res.ok) {
          localStorage.removeItem(WL_DRAFT_KEY);
          if (form) form.style.display = 'none';
          if (successEl) successEl.style.display = 'block';
        } else {
          if (errorEl) {
            errorEl.textContent = data.error ?? 'Submission failed — please try again.';
            errorEl.style.display = 'block';
          }
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Application';
        }
      } catch {
        if (errorEl) {
          errorEl.textContent = 'Network error — please check your connection and try again.';
          errorEl.style.display = 'block';
        }
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Application';
      }
    });
  </script>

  <script>
    const WORKER_URL = "https://royal-truth-48c4-capital-roleplay-discordcounter.skagebakk.workers.dev";
    // Discord widget API — CORS-enabled, gives online count as a direct fallback
    const WIDGET_URL = "https://discord.com/api/guilds/1478455683576893472/widget.json";
    const CACHE_M    = "dc_members";
    const CACHE_O    = "dc_online";

    const memberEl = document.getElementById("discordMemberCount");
    const onlineEl = document.getElementById("discordOnlineCount");

    // Seed from localStorage so returning visitors see real numbers instantly
    let lastMembers = parseInt(localStorage.getItem(CACHE_M) ?? "0", 10);
    let lastOnline  = parseInt(localStorage.getItem(CACHE_O) ?? "0", 10);
    let retryTimer: ReturnType<typeof setTimeout> | null = null;

    function fmt(n: number) {
      return new Intl.NumberFormat("en-GB").format(n);
    }

    function render() {
      if (memberEl) memberEl.textContent = lastMembers > 0 ? fmt(lastMembers) : "—";
      if (onlineEl) onlineEl.textContent  = lastOnline  > 0 ? fmt(lastOnline)  : "—";
    }

    // Show cached values immediately — no blank state on repeat visits
    render();

    // Fallback: hit Discord widget directly for online count (no bot token needed)
    async function tryWidget() {
      try {
        const res = await fetch(WIDGET_URL, { cache: "no-store" });
        if (!res.ok) return false;
        const d = await res.json();
        if (d.code === 50004) return false; // widget disabled
        if (typeof d.presence_count === "number" && d.presence_count > 0) {
          if (lastOnline === 0 || Math.abs(d.presence_count - lastOnline) > 1) {
            lastOnline = d.presence_count;
            localStorage.setItem(CACHE_O, String(lastOnline));
            render();
          }
          return true;
        }
      } catch { /* widget unreachable */ }
      return false;
    }

    async function loadDiscordStats(retryCount = 0): Promise<void> {
      try {
        const res = await fetch(WORKER_URL, { cache: "no-store" });
        if (!res.ok) throw new Error("HTTP " + res.status);
        const data = await res.json();

        const gotMembers = typeof data.members === "number" && data.members > 0;
        const gotOnline  = typeof data.online  === "number" && data.online  > 0;

        // ±1 guard — only update if the change is meaningful (filters Discord's approximate noise)
        if (gotMembers && (lastMembers === 0 || Math.abs(data.members - lastMembers) > 1)) {
          lastMembers = data.members;
          localStorage.setItem(CACHE_M, String(lastMembers));
        }
        if (gotOnline && (lastOnline === 0 || Math.abs(data.online - lastOnline) > 1)) {
          lastOnline = data.online;
          localStorage.setItem(CACHE_O, String(lastOnline));
        }

        render();

        // Worker gave zeros — try widget for online count, then schedule retry
        if (!gotOnline)  await tryWidget();
        if ((!gotMembers || !gotOnline) && retryCount < 8) {
          clearTimeout(retryTimer!);
          retryTimer = setTimeout(() => loadDiscordStats(retryCount + 1), Math.min(2500 * (retryCount + 1), 15_000));
        }
      } catch {
        // Worker completely unreachable — try widget, then retry
        await tryWidget();
        if (retryCount < 6) {
          clearTimeout(retryTimer!);
          retryTimer = setTimeout(() => loadDiscordStats(retryCount + 1), Math.min(3000 * (retryCount + 1), 15_000));
        }
      }
    }

    loadDiscordStats();
    setInterval(() => loadDiscordStats(), 30_000); // poll every 30s (was 60s)
  </script>

  <script>
    // ── FiveM Live Server Stats ──────────────────────────────────────────────
    const FIVEM_CACHE_P = "fivem_players";
    const FIVEM_CACHE_M = "fivem_max";

    const fivemPanelEl    = document.getElementById("fivemPanel");
    const fivemCountEl    = document.getElementById("fivemPlayerCount");
    const fivemMaxEl      = document.getElementById("fivemMaxPlayers");
    const fivemLabelEl    = document.getElementById("fivemStatusLabel");
    const fivemConnectBtn = document.getElementById("fivemConnectBtn") as HTMLAnchorElement | null;

    let cachedPlayers = parseInt(localStorage.getItem(FIVEM_CACHE_P) ?? "0", 10);
    let cachedMax     = parseInt(localStorage.getItem(FIVEM_CACHE_M) ?? "0", 10);
    let displayedPlayers = cachedPlayers;
    let stickyMax     = cachedMax;          // last known good maxPlayers — never decays to 0
    let offlineStreak = 0;                  // consecutive offline reports
    const OFFLINE_FLIP_AFTER = 2;           // require N back-to-back offline reports before flipping UI

    // Animate the count from current displayed value to target — gives the
    // counter a "live, breathing" feel when the number changes.
    function animateCount(from: number, to: number) {
      if (!fivemCountEl) return;
      if (from === to) { fivemCountEl.textContent = String(to); return; }

      const start = performance.now();
      const dur   = Math.min(800, 120 + Math.abs(to - from) * 60);
      const delta = to - from;

      function step(now: number) {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
        const v = Math.round(from + delta * eased);
        if (fivemCountEl) fivemCountEl.textContent = String(v);
        if (t < 1) requestAnimationFrame(step);
        else {
          // brief "bump" highlight when the value lands on a new number
          fivemCountEl?.classList.remove("pm-num--bump");
          void fivemCountEl?.offsetWidth;
          fivemCountEl?.classList.add("pm-num--bump");
        }
      }
      requestAnimationFrame(step);
    }

    function renderFiveM(players: number, maxPlayers: number, online: boolean) {
      // maxPlayers never decays — once we know it's 128, keep showing 128.
      if (maxPlayers > 0) stickyMax = maxPlayers;
      if (fivemMaxEl) fivemMaxEl.textContent = stickyMax > 0 ? String(stickyMax) : "—";

      fivemPanelEl?.classList.toggle("is-online", online);
      fivemPanelEl?.classList.toggle("is-offline", !online);

      if (online) {
        if (fivemCountEl) {
          if (displayedPlayers !== players) {
            animateCount(displayedPlayers, players);
            displayedPlayers = players;
          } else {
            fivemCountEl.textContent = String(players);
          }
        }
      } else {
        if (fivemCountEl) fivemCountEl.textContent = "—";
        displayedPlayers = 0;
      }

      const pillEl = document.getElementById("fivemStatusPill");
      if (pillEl) {
        pillEl.className = "fc-status-tag pm-status-tag " + (online ? "fc-status-tag--live" : "fc-status-tag--popular");
      }
      if (fivemLabelEl) {
        fivemLabelEl.textContent = online ? "Live" : "Offline";
      }
      if (fivemConnectBtn) {
        if (online) {
          fivemConnectBtn.classList.remove("is-offline");
          fivemConnectBtn.innerHTML = 'Connect to server <i class="fa-solid fa-arrow-right"></i>';
        } else {
          fivemConnectBtn.classList.add("is-offline");
          fivemConnectBtn.textContent = "Server is currently offline";
        }
      }
    }

    // Seed cached values instantly — no blank state for returning visitors
    if (cachedMax > 0) renderFiveM(cachedPlayers, cachedMax, true);

    // Don't flip to "Offline" on a single bad report — the worker's data
    // sources (FXServer endpoints, CFX) are flaky and an isolated failure
    // is almost never a real outage. Require N consecutive offline reports.
    function applyOnlineSmoothing(reportedOnline: boolean) {
      if (reportedOnline) {
        offlineStreak = 0;
        return true;
      }
      offlineStreak += 1;
      // While we're below the flip threshold, keep showing the previous state.
      // If we've never seen the server online (no cached max), report offline immediately.
      if (offlineStreak < OFFLINE_FLIP_AFTER && stickyMax > 0) return true;
      return false;
    }

    async function loadFiveMStats(): Promise<void> {
      try {
        const res = await fetch("/api/fivem", { cache: "no-store" });
        if (!res.ok) throw new Error("HTTP " + res.status);
        const data = await res.json() as { players: number; maxPlayers: number; online: boolean; connectUrl: string };

        if (data.maxPlayers > 0) {
          localStorage.setItem(FIVEM_CACHE_P, String(data.players));
          localStorage.setItem(FIVEM_CACHE_M, String(data.maxPlayers));
        }

        if (fivemConnectBtn && data.connectUrl) {
          fivemConnectBtn.href = data.connectUrl;
        }

        const effectiveOnline = applyOnlineSmoothing(data.online);
        // While smoothing keeps us "online" but the worker reported offline,
        // hold the previous player count rather than animating to the worker's 0.
        const effectivePlayers = effectiveOnline && !data.online ? displayedPlayers : data.players;
        renderFiveM(effectivePlayers, data.maxPlayers, effectiveOnline);
      } catch {
        // /api/fivem unreachable — same smoothing as a worker-reported offline.
        const effectiveOnline = applyOnlineSmoothing(false);
        renderFiveM(effectiveOnline ? displayedPlayers : 0, cachedMax, effectiveOnline);
      }
    }

    loadFiveMStats();
    setInterval(loadFiveMStats, 30_000);
  </script>
</MainLayout>
